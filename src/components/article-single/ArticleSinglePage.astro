---
import type { AdaptedPage } from '@/lib/page-adapter';
import ArticleContent from './ArticleContent.astro';
import ArticleFooter from './ArticleFooter.astro';
import ArticleHero from './ArticleHero.astro';
import ArticleToc from './ArticleToc.astro';
import RelatedArticles from './RelatedArticles.astro';

interface Props {
  page: AdaptedPage;
  lang?: string;
}

const { page, lang = 'en' } = Astro.props;
const article = page.article;
---
{article && (
  <main class="soeteck-single-post single-post--blogs">
    <article class="soeteck-single-post__article">
      <ArticleHero article={article} breadcrumbs={page.breadcrumbs} lang={lang} />
      <div class="container soeteck-single-post__body-shell">
        <ArticleToc />
        <div class="soeteck-single-post__content-wrap">
          <ArticleContent contentHtml={article.contentHtml} />
          <ArticleFooter article={article} />
        </div>
      </div>
    </article>
    <RelatedArticles />
  </main>
)}

<style>
  .soeteck-single-post {
    --soeteck-single-post-content: 1200px;
    --soeteck-single-post-gutter: 20px;
    background: var(--soeteck-white);
  }

  .soeteck-single-post :global(.container) {
    width: min(var(--soeteck-single-post-content), calc(100% - (var(--soeteck-single-post-gutter) * 2)));
    max-width: none;
    margin-inline: auto;
    padding-inline: 0;
  }

  .soeteck-single-post__body-shell {
    position: relative;
    padding-bottom: clamp(56px, 7vw, 96px);
  }

  @media (max-width: 768px) {
    .soeteck-single-post {
      --soeteck-single-post-gutter: 16px;
    }
  }
</style>
