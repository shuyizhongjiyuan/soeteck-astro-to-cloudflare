  color: var(--soeteck-text);
  font-size: 13px;
  line-height: 1.25;
  cursor: pointer;
  transition: background var(--soeteck-transition-fast), color var(--soeteck-transition-fast);
}

.soeteck-filter-option:hover,
.soeteck-filter-option:global(.is-checked) {
  background: rgba(30, 144, 255, 0.08);
  color: var(--soeteck-primary-dark);
}

.soeteck-filter-option input {
  flex: 0 0 auto;
  width: 14px;
  height: 14px;
  accent-color: var(--soeteck-primary);
}

/* Filter Actions */
.soeteck-product-filters__actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 6px;
  max-height: 0;
  margin-top: 0;
  overflow: hidden;
  opacity: 0;
  pointer-events: none;
  transform: translateY(-4px);
  transition: max-height 220ms ease, margin-top 220ms ease, opacity 160ms ease, transform 200ms ease;
}

.soeteck-product-filters:global(.has-active-filters) .soeteck-product-filters__actions,
.soeteck-product-filters:global(.has-pending-filters) .soeteck-product-filters__actions {
  max-height: 48px;
  margin-top: 10px;
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.soeteck-product-filters__clear-action {
  display: inline-flex;
  font-family: var(--soeteck-font-ui);
  align-items: center;
  justify-content: center;
  min-height: 34px;
  padding: 0 6px;
  background: #e8eef5;
  color: #1f2937;
  font-size: 14px;
  font-weight: var(--soeteck-weight-medium);
  line-height: 1.2;
  text-align: center;
  text-decoration: none;
  cursor: pointer;
  transition: background var(--soeteck-transition-fast), color var(--soeteck-transition-fast), box-shadow var(--soeteck-transition-fast), transform 120ms ease;
}

.soeteck-product-filters__clear-action:hover {
  background: #dbe5ef;
  color: #0f172a;
  text-decoration: none;
}

.soeteck-product-filters__clear-action:active,
.soeteck-product-filters:global(.is-resetting) .soeteck-product-filters__clear-action {
  background: #cbd8e6;
  box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.18);
  transform: translateY(1px);
}

.soeteck-product-filters__submit {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38px;
  padding: 0 24px;
  border: 1px solid var(--soeteck-primary);
  border-radius: 0;
  background: var(--soeteck-primary);
  color: var(--soeteck-white);
  font-family: var(--soeteck-font-ui);
  font-size: 14px;
  font-weight: var(--soeteck-weight-semibold);
  line-height: 1.2;
  white-space: nowrap;
  cursor: pointer;
  transition: background var(--soeteck-transition-fast), color var(--soeteck-transition-fast), border-color var(--soeteck-transition-fast), transform var(--soeteck-transition-fast);
}

.soeteck-product-filters__submit:hover {
  background: var(--soeteck-primary-dark);
  border-color: var(--soeteck-primary-dark);
  transform: translateY(-1px);
}

.soeteck-product-filters__submit:focus-visible {
  outline: 2px solid var(--soeteck-primary);
  outline-offset: 2px;
}

.soeteck-product-filters__submit:active {
  background: var(--soeteck-primary-dark);
  box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.2);
  transform: translateY(1px);
}

/* Active Filters */
:global(.soeteck-active-filters) {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10px;
  margin-bottom: 18px;
}

:global(.soeteck-active-filter) {
  display: inline-flex;
  font-family: var(--soeteck-font-ui);
  align-items: center;
  gap: 8px;
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  background: var(--soeteck-primary-soft);
  color: var(--soeteck-primary-dark);
  font-size: var(--soeteck-text-sm);
  font-weight: var(--soeteck-weight-medium);
  text-decoration: none;
  transition: background var(--soeteck-transition-fast), color var(--soeteck-transition-fast), opacity 160ms ease, transform 160ms ease;
}

:global(.soeteck-active-filter):hover {
  background: var(--soeteck-primary);
  color: var(--soeteck-white);
}

:global(.soeteck-active-filter):global(.is-removing) {
  background: #fee2e2;
  color: #991b1b;
  opacity: 0.9;
  transform: scale(0.97);
}

:global(.soeteck-active-filter):active,
:global(.soeteck-active-filter):global(.is-removing):hover {
  background: #dc2626;
  color: var(--soeteck-white);
}

/* Intro Blocks */
.soeteck-product-results__intro {
  margin: 0 0 25px;
}

.soeteck-product-results__intro p {
  margin: 0;
  font-family: var(--soeteck-font-body);
  color: var(--soeteck-text);
  font-size: 16px;
  line-height: 1.5;
}

.soeteck-product-results__intro strong {
  font-weight: var(--soeteck-weight-bold);
}

/* Toolbar */
.soeteck-product-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  min-height: 62px;
  margin-bottom: 18px;
}

.soeteck-product-toolbar__count p {
  margin: 0;
  color: var(--soeteck-text);
  font-size: 14px;
}

.soeteck-product-toolbar__form,
.soeteck-product-toolbar__controls {
  display: flex;
  align-items: end;
  gap: 8px;
}

.soeteck-product-toolbar__label {
  display: block;
  font-family: var(--soeteck-font-ui);
  color: var(--soeteck-text);
  font-size: 14px;
  line-height: 1.2;
}

.soeteck-product-toolbar__select {
  min-width: 146px;
  font-family: var(--soeteck-font-ui);
  min-height: 36px;
  padding: 0 40px 0 12px;
  border: 1px solid rgba(16, 24, 40, 0.16);
  border-radius: 3px;
  appearance: none;
  background-color: var(--soeteck-white);
  background-image: linear-gradient(45deg, transparent 50%, #1f2937 50%), linear-gradient(135deg, #1f2937 50%, transparent 50%);
  background-position: calc(100% - 18px) 50%, calc(100% - 13px) 50%;
  background-size: 5px 5px, 5px 5px;
  background-repeat: no-repeat;
  color: var(--soeteck-text);
  font-size: 13px;
  line-height: 1.2;
  cursor: pointer;
}

.soeteck-product-toolbar__select:hover {
  border-color: rgba(16, 24, 40, 0.34);
}

.soeteck-product-toolbar__select:focus {
  border-color: var(--soeteck-primary);
  box-shadow: 0 0 0 3px rgba(0, 102, 204, 0.12);
  outline: none;
}

.soeteck-product-toolbar__select option:disabled {
  color: #64748b;
  font-weight: var(--soeteck-weight-semibold);
}

.soeteck-product-toolbar__submit {
  position: absolute;
  width: 1px;
  height: 1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
}

/* Product List */
:global(.soeteck-product-list) {
  display: grid;
  gap: 18px;
}

:global(.soeteck-product-list-item) {
  display: block;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  border: 1px solid #aeb4bb;
  background: #f7f7f7;
  box-shadow: none;
  transition: border-color 180ms ease, box-shadow 180ms ease;
}

:global(.soeteck-product-list-item:hover),
:global(.soeteck-product-list-item:focus-within) {
  border-color: var(--soeteck-primary);
  box-shadow: 2px 4px 5px rgba(0, 0, 0, 0.22);
}

/* Product Card — 3-column horizontal */
:global(.soeteck-product-list-card) {
  display: grid;
  grid-template-columns: 230px minmax(0, 1fr) 172px;
  align-items: center;
  min-height: 245px;
  background: #f7f7f7;
}

/* Card Media / Gallery */
:global(.soeteck-product-list-card__media) {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 245px;
  padding: 30px 14px 42px;
  overflow: visible;
  background: transparent;
  cursor: grab;
  user-select: none;
}

:global(.soeteck-product-list-card__media.is-dragging) {
  cursor: grabbing;
}

:global(.soeteck-product-list-card__gallery-viewport) {
  display: block;
  width: calc(100% - 28px);
  overflow: hidden;
}

:global(.soeteck-product-list-card__gallery-track) {
  display: flex;
  width: 100%;
  height: 150px;
  transform: translateX(calc((var(--gallery-index, 0) * -100%) + var(--gallery-drag-offset, 0px)));
  transition: transform 220ms ease;
}

:global(.soeteck-product-list-card__media.is-dragging) :global(.soeteck-product-list-card__gallery-track) {
  transition: none;
}

:global(.soeteck-product-list-card__gallery.is-looping-forward) :global(.soeteck-product-list-card__gallery-track) {
  transition-duration: 286ms;
}

:global(.soeteck-product-list-card__gallery-slide) {
  display: flex;
  flex: 0 0 100%;
  align-items: center;
  justify-content: center;
  padding: 0 6px;
  pointer-events: none;
}

:global(.soeteck-product-list-card__media) img {
  display: block;
  width: auto;
  max-width: 205px;
  max-height: 155px;
  object-fit: contain;
  pointer-events: none;
}

/* Gallery Dots */
:global(.soeteck-product-list-card__media-dots) {
  position: absolute;
  left: 50%;
  bottom: 24px;
  display: inline-flex;
  align-items: center;
  gap: 2px;
  transform: translateX(-50%);
}

:global(.soeteck-product-list-card__media-dots) button {
  position: relative;
  width: 12px;
  height: 12px;
  padding: 0;
  border: 0;
  border-radius: 50%;
  background: transparent;
  cursor: pointer;
}

:global(.soeteck-product-list-card__media-dots) button::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #b8b8b8;
  transform: translate(-50%, -50%);
}

:global(.soeteck-product-list-card__media-dots) button:global(.is-active)::before,
:global(.soeteck-product-list-card__media-dots) button:hover::before {
  background: #000;
}

/* Card Content */
:global(.soeteck-product-list-card__content) {
  min-width: 0;
  padding: 46px 10px 44px 0;
}

:global(.soeteck-product-list-card__title) {
  margin: 0;
  font-family: var(--soeteck-font-heading);
  color: var(--soeteck-text);
  font-size: 18px;
  font-weight: var(--soeteck-weight-bold);
  line-height: 1.35;
}

:global(.soeteck-product-list-card__title a) {
  color: inherit !important;
  text-decoration: none;
}

:global(.soeteck-product-list-card__title a:hover) {
  color: var(--soeteck-primary) !important;
}

:global(.soeteck-product-list-card__excerpt) {
  display: -webkit-box;
  margin: 16px 0 0;
  overflow: hidden;
  font-family: var(--soeteck-font-body);
  color: var(--soeteck-text);
  font-size: 14px;
  line-height: 1.55;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

/* Card Actions */
:global(.soeteck-product-list-card__actions) {
  align-self: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8px;
  min-height: 170px;
  padding: 24px 16px;
  background: #d7d7d7;
}

:global(.soeteck-product-list-card__button) {
  display: inline-flex;
  font-family: var(--soeteck-font-ui);
  align-items: center;
  justify-content: center;
  gap: 6px;
  min-height: 30px;
  padding: 0 12px;
  border: 0;
  border-radius: 4px;
  background: var(--soeteck-primary);
  color: var(--soeteck-white);
  font-size: 13px;
  font-weight: var(--soeteck-weight-semibold);
  line-height: 1.2;
  text-decoration: none;
  cursor: pointer;
}

:global(.soeteck-product-list-card__button):hover {
  background: var(--soeteck-primary-dark);
  color: var(--soeteck-white);
}

/* Models */
:global(.soeteck-product-list-item__models) {
  display: grid;
  grid-template-rows: 0fr;
  width: 100%;
  overflow: hidden;
  overflow-y: hidden;
  padding: 0 10px;
  border-top: 1px solid transparent;
  background: var(--soeteck-white);
  opacity: 0;
  transform: translateY(-6px);
  transition:
    grid-template-rows 260ms ease,
    padding 260ms ease,
    border-color 260ms ease,
    opacity 180ms ease,
    transform 260ms ease;
}

:global(.soeteck-product-list-item__models):global(.show) {
  grid-template-rows: 1fr;
  padding: 10px 10px 0;
  border-top-color: rgba(16, 24, 40, 0.14);
  opacity: 1;
  transform: translateY(0);
}

:global(.soeteck-product-list-card__button):global(.show-variations)::after {
  content: '';
  display: block;
  flex: 0 0 auto;
  width: 6px;
  height: 6px;
  border-right: 1.35px solid currentColor;
  border-bottom: 1.35px solid currentColor;
  transform: translateX(-1px) rotate(-45deg);
  transform-origin: center;
  transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

:global(.soeteck-product-list-card__button):global(.show-variations)[aria-expanded="true"]::after,
:global(.soeteck-product-list-card__button):global(.show-variations):global(.is-expanded)::after {
  transform: translateY(-2px) rotate(45deg);
}

:global(.soeteck-product-list-card__button):global(.show-variations) i {
  display: none;
}

:global(.soeteck-product-list-item__models) :global(.variations-table) {
  overflow-x: auto;
  overflow-y: hidden;
  min-height: 0;
  max-width: 100%;
  margin: 0;
  border-bottom: 1px solid rgba(16, 24, 40, 0.14);
  background: var(--soeteck-white);
}

:global(.soeteck-product-list-item__models) :global(table) {
  width: max-content;
  font-family: var(--soeteck-font-ui);
  min-width: 100%;
  margin-bottom: 10px;
  border-collapse: collapse;
  color: var(--soeteck-text);
}

:global(.soeteck-product-list-item__models) :global(th),
:global(.soeteck-product-list-item__models) :global(td),
:global(.soeteck-product-list-item__models) :global(.variations-table) :global(th),
:global(.soeteck-product-list-item__models) :global(.variations-table) :global(td) {
  padding: 6px 10px;
  border-bottom: 1px solid rgba(16, 24, 40, 0.1);
  font-size: 12px;
  line-height: 1.35;
  text-align: left;
  vertical-align: middle;
  white-space: nowrap;
}

:global(.soeteck-product-list-item__models) :global(th),
:global(.soeteck-product-list-item__models) :global(.variations-table) :global(th) {
  background: #e8eef5;
  color: #1f2937;
  font-weight: var(--soeteck-weight-semibold);
}

:global(.soeteck-product-list-item__models) :global(td):first-child,
:global(.soeteck-product-list-item__models) :global(.variations-table) :global(td):first-child {
  color: #0f172a;
  font-weight: var(--soeteck-weight-semibold);
}

:global(.soeteck-product-list-item__models) :global(tbody) :global(tr):hover :global(td) {
  background: rgba(232, 238, 245, 0.55);
}

:global(.soeteck-product-list-item__models) :global(.variation-row--extra) {
  display: none;
}

:global(.soeteck-product-list-item__models) :global(.variations-table.is-expanded) :global(.variation-row--extra) {
  display: table-row;
}

:global(.soeteck-product-list-item__models) :global(.toggle-variations-wrap) {
  display: flex;
  justify-content: flex-end;
  margin-top: 0;
  margin-bottom: 10px;
  padding: 0 22px 0;
  background: var(--soeteck-white);
}

:global(.soeteck-product-list-item__models) :global(.toggle-variations) {
  display: inline-flex;
  font-family: var(--soeteck-font-ui);
  align-items: center;
  gap: 6px;
  min-height: 22px;
  padding: 0;
  border: 0;
  background: transparent;
  color: var(--soeteck-primary);
  font-size: 12px;
  font-weight: var(--soeteck-weight-medium);
  cursor: pointer;
}

:global(.soeteck-product-list-item__models) :global(.toggle-variations)::after {
  content: '';
  width: 7px;
  height: 7px;
  border-right: 1.5px solid currentColor;
  border-bottom: 1.5px solid currentColor;
  transform: translateY(-2px) rotate(45deg);
  transition: transform var(--soeteck-transition-fast);
}

:global(.soeteck-product-list-item__models) :global(.toggle-variations.is-expanded)::after {
  transform: translateY(2px) rotate(225deg);
}

:global(.soeteck-product-list-item__models) :global(.toggle-variations):hover {
  color: var(--soeteck-primary-dark);
}

/* Empty state */
:global(.soeteck-product-empty) {
  padding: 48px 0;
  text-align: center;
  color: var(--soeteck-text-soft);
  font-size: 16px;
}

/* Pagination */
.soeteck-product-results :global(.woocommerce-pagination) {
  margin-top: clamp(40px, 6vw, 72px);
}

.soeteck-product-results :global(.woocommerce-pagination ul.page-numbers) {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8px;
  width: auto;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  list-style: none;
}

.soeteck-product-results :global(.woocommerce-pagination ul.page-numbers li) {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
}

.soeteck-product-results :global(.woocommerce-pagination ul.page-numbers li::before),
.soeteck-product-results :global(.woocommerce-pagination ul.page-numbers li::after),
.soeteck-product-results :global(.woocommerce-pagination ul.page-numbers li + li::before) {
  display: none;
  content: none;
}

.soeteck-product-results :global(.woocommerce-pagination ul.page-numbers > li > .page-numbers) {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  min-width: 42px;
  height: 42px;
  min-height: 42px;
  padding: 0;
  border: 1px solid var(--soeteck-border-soft);
  border-radius: var(--soeteck-radius-sm);
  background: transparent;
  box-shadow: none;
  color: var(--soeteck-text);
  font-family: var(--soeteck-font-ui);
  font-size: var(--soeteck-text-sm);
  font-weight: var(--soeteck-weight-medium);
  line-height: 1;
  text-align: center;
  text-decoration: none;
  transition: border-color var(--soeteck-transition-fast), background-color var(--soeteck-transition-fast), color var(--soeteck-transition-fast);
}

.soeteck-product-results :global(.woocommerce-pagination ul.page-numbers > li > .prev),
.soeteck-product-results :global(.woocommerce-pagination ul.page-numbers > li > .next) {
  font-size: 16px;
}

.soeteck-product-results :global(.woocommerce-pagination ul.page-numbers > li > .page-numbers.current),
.soeteck-product-results :global(.woocommerce-pagination ul.page-numbers > li > .page-numbers:hover) {
  border-color: var(--soeteck-primary);
  background: var(--soeteck-primary);
  box-shadow: none;
  color: var(--soeteck-white);
}

.soeteck-product-results :global(.woocommerce-pagination ul.page-numbers > li > .page-numbers.dots) {
  border-color: transparent;
  background: transparent;
  color: var(--soeteck-muted);
}

/* Reduced Motion */
@media (prefers-reduced-motion: reduce) {
  :global(.soeteck-product-list-item__models),
  .soeteck-product-category-switcher__panel,
  .soeteck-product-filters__panel,
  .soeteck-product-filters__overlay,
  .soeteck-product-filters__actions,
  .soeteck-filter-group__panel,
  .soeteck-filter-group__chevron,
  :global(.soeteck-product-list-card__gallery-slide),
  :global(.soeteck-product-list-card__gallery-track) {
    transition: none;
  }
}

/* ========================================
   Responsive Breakpoints
   ======================================== */

@media (max-width: 1200px) {
  .soeteck-product-category-layout {
    grid-template-columns: 250px minmax(0, 1fr);
    gap: 22px;
  }

  :global(.soeteck-product-list-card) {
    grid-template-columns: 210px minmax(0, 1fr) 164px;
  }

  :global(.soeteck-product-list-card__media) img {
    max-width: 188px;
  }
}

@media (max-width: 991px) {
  .soeteck-product-cat-hero {
    min-height: 420px;
  }

  .soeteck-product-category-body {
    padding-top: 80px;
  }

  .soeteck-product-category-layout {
    grid-template-columns: minmax(0, 1fr);
    min-width: 0;
  }

  .soeteck-product-results,
  :global(.soeteck-product-list),
  :global(.soeteck-product-list-item),
  :global(.soeteck-product-list-card) {
    min-width: 0;
    max-width: 100%;
  }

  .soeteck-product-filters {
    position: static;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 8px;
    max-height: none;
  }

  .soeteck-product-filters__mobile-bar {
    display: block;
    grid-column: 2;
    grid-row: 1;
  }

  .soeteck-product-category-switcher {
    grid-column: 1;
    grid-row: 1;
  }

  .soeteck-product-filters__mobile-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    min-height: 42px;
    padding: 0;
    border: 1px solid var(--soeteck-primary);
    background: var(--soeteck-primary);
    color: var(--soeteck-white);
    font-size: 0;
    cursor: pointer;
  }

  .soeteck-product-filters__mobile-toggle::before,
  .soeteck-product-filters__mobile-toggle::after {
    content: '';
    position: absolute;
    left: 10px;
    width: 20px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
  }

  .soeteck-product-filters__mobile-toggle::before {
    top: 12px;
    box-shadow: 0 14px 0 currentColor;
  }

  .soeteck-product-filters__mobile-toggle::after {
    top: 19px;
