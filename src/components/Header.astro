---
import type { GlobalConfigResponse } from '@/lib/content-api';
import { getUITranslation } from '@/lib/translations';

interface Props {
  globalConfig: GlobalConfigResponse;
  lang?: string;
}

const { globalConfig, lang = 'en' } = Astro.props;

// 将 API 返回的 /en/ 路径转为当前语言路径
function localizePath(apiPath: string): string {
  if (lang === 'en') return apiPath;
  return apiPath.replace(/^\/en\//, `/${lang}/`);
}

// 翻译导航标签
const navMap: Record<string, string> = {
  'Products': 'nav.products',
  'Solutions': 'nav.solutions',
  'News & Insights': 'nav.news',
  'About Soeteck': 'nav.about',
  'Contact Us': 'nav.contact',
  'Home': 'nav.home',
};
function translateNav(title: string): string {
  if (lang === 'en') return title;
  const key = navMap[title];
  return key ? getUITranslation(lang, key) : title;
}

// 翻译 Mega Menu 中的分类标题（API 返回英文，需映射到翻译 key）
const categoryMap: Record<string, string> = {
  'Critical Power': 'category.criticalPower',
  'Thermal Management': 'category.thermalManagement',
  'Racks & Enclosures': 'category.racksEnclosures',
  'Monitoring & Management': 'category.monitoringManagement',
  'Prefabricated Data Center': 'category.prefabDC',
  'Colocation Data Center': 'category.colocationDC',
  'Edge Computing': 'category.edgeComputing',
  'News Releases': 'category.newsReleases',
  'Blogs': 'category.blogs',
  'Client Case Studies': 'category.caseStudies',
  'Liquid Cooling Data Center': 'solutions.liquidCoolingDC',
  'Prefabricated Container Data Center': 'solutions.prefabContainerDC',
  'Cabinet Modular Data Center': 'solutions.cabinetModularDC',
  'Row Modular Data Center': 'solutions.rowModularDC',
  'Aisle Modular Data Center': 'solutions.aisleModularDC',
  'Uninterruptible Power Supplies': 'products.uninterruptiblePowerSupplies',
  'DC Power Systems': 'products.dcPowerSystems',
  'Power Distribution': 'products.powerDistribution',
  'Static Transfer Switches': 'products.staticTransferSwitches',
  'Busway and Busduct': 'products.buswayAndBusduct',
  'Battery': 'products.battery',
  'Liquid Cooling Solutions': 'products.liquidCoolingSolutions',
  'Precision Air Conditioning': 'products.precisionAirConditioning',
  'Room Cooling': 'products.roomCooling',
  'In-Row Cooling': 'products.inRowCooling',
  'Rack Cooling': 'products.rackCooling',
  'Pumped Refrigerant Cooling': 'products.pumpedRefrigerantCooling',
  'Telecom Enclosure Air Conditioner': 'products.telecomEnclosureAirConditioner',
  'Heat Rejection': 'products.heatRejection',
  'Evaporative Free Cooling': 'products.evaporativeFreeCooling',
  'Free Cooling Chillers': 'products.freeCoolingChillers',
  'Integrated Containments': 'products.integratedContainments',
  'Outdoor Enclosures': 'products.outdoorEnclosures',
  'Racks & Cabinets': 'products.racksAndCabinets',
  'Monitoring Host': 'products.monitoringHost',
  'Battery Monitoring System': 'products.batteryMonitoringSystem',
  'Environmental Sensor': 'products.environmentalSensor',
  'Rack Asset Management': 'products.rackAssetManagement',
  'KVM': 'products.kvm',
};
function translateCategoryTitle(title: string): string {
  if (lang === 'en') return title;
  const key = categoryMap[title];
  return key ? getUITranslation(lang, key) : title;
}

// Detect menu variant type from URL path (fallback when API type is 'default')
function detectMenuType(item: { path?: string; type?: string; children?: unknown[] }): string {
  if (item.type && item.type !== 'default') return item.type;
  const p = (item.path || '').toLowerCase();
  if (p.includes('/products')) return 'product';
  if (p.includes('/solutions')) return 'solution';
  if (p.includes('/news')) return 'news';
  return 'default';
}

// 生成目标语言的当前页面链接
function getLanguageUrl(targetLang: string): string {
  const currentPath = Astro.url.pathname;
  // 移除当前语言前缀，添加目标语言前缀
  const pathWithoutLang = currentPath.replace(/^\/(en|zh|ru|pt|es)/, '') || '/';
  return `/${targetLang}${pathWithoutLang}`;
}

// Use data from API, fall back to defaults if not available
const mainNavigation = globalConfig.mainNavigation || [];
const languages = globalConfig.languages || [
  { slug: 'en', name: 'English', nativeName: 'English', flag: { path: '/resources/flags/en.svg' }, url: '/en/', isCurrent: true },
  { slug: 'zh', name: 'Chinese', nativeName: '中文', flag: { path: '/resources/flags/zh.svg' }, url: '/zh/', isCurrent: false },
  { slug: 'ru', name: 'Russian', nativeName: 'Русский', flag: { path: '/resources/flags/ru.svg' }, url: '/ru/', isCurrent: false },
  { slug: 'pt', name: 'Portuguese', nativeName: 'Português', flag: { path: '/resources/flags/pt.svg' }, url: '/pt/', isCurrent: false },
  { slug: 'es', name: 'Spanish', nativeName: 'Español', flag: { path: '/resources/flags/es.svg' }, url: '/es/', isCurrent: false },
];
const currentLanguage = globalConfig.currentLanguage || languages[0];
const logoUrl = globalConfig.site.logo?.path || '/resources/soeteck-logo-2.webp';
const contactUrl = localizePath(globalConfig.urls.contact || '/en/contact-us/');
---

<header id="masthead" class="site-header">
  <div class="header-inner">
    <a class="site-logo-link" href={localizePath("/en/")} rel="home" aria-label="Soeteck">
      <img class="site-logo-image" src={logoUrl} alt="Soeteck" width="240" height="59">
    </a>

    <button class="menu-toggle" type="button" aria-controls="mobile-menu-overlay" aria-expanded="false" aria-label="Open menu">
      <span class="menu-toggle-line"></span>
      <span class="menu-toggle-line"></span>
      <span class="menu-toggle-line"></span>
    </button>

    <nav id="site-navigation" class="main-navigation" aria-label="Primary menu">
      <ul class="primary-menu">
        {mainNavigation.map(item => {
          const titleKey = item.title.toLowerCase()
          const isContact = titleKey === 'contact us'
          if (isContact) return null

          const hasChildren = !!(item.children && item.children.length)
          const menuType = detectMenuType(item)
          const variantClass =
            menuType === 'product' ? ' menu-products' :
            menuType === 'solution' ? ' menu-solutions' :
            menuType === 'news' ? ' menu-news' : ''

          return (
            <li class={`primary-menu-item${hasChildren ? ' has-megamenu' : ''}${variantClass}`}>
              <a class="primary-menu-link" href={localizePath(item.path)}>
                {translateNav(item.title)}
              </a>

              {hasChildren && (
                <>
                  <button class="submenu-toggle" type="button" aria-expanded="false" aria-label={`Open ${item.title} menu`}>
                    <svg class="dropdown-chevron" aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" focusable="false">
                      <path d="M4 6l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </button>
                  <div class="megamenu-panel" aria-label={item.title}>
                    {menuType === 'news' && (
                      <div class="news-megamenu-inner">
                        {item.children.map(newsCategory => {
                          const categoryKey = newsCategory.title.toLowerCase()
                          const subtitles = {
                            'news releases': getUITranslation(lang, 'megamenu.newsSubtitle1'),
                            'blogs': getUITranslation(lang, 'megamenu.newsSubtitle2'),
                            'client case studies': getUITranslation(lang, 'megamenu.newsSubtitle3'),
                          }
                          const subtitle = subtitles[categoryKey] || ''
                          const np = (newsCategory as any).newsPosts as { featured: any; list: any[] } | undefined
                          const featuredPost = np?.featured ?? null
                          const latestPosts = np?.list ?? []

                          return (
                            <section class="news-megamenu-column">
                              <a class="news-megamenu-heading" href={localizePath(newsCategory.path)}>
                                <span class="news-megamenu-marker" aria-hidden="true"></span>
                                <span>{translateCategoryTitle(newsCategory.title)}</span>
                              </a>
                              {subtitle && <p class="news-megamenu-subtitle">{subtitle}</p>}

                              {featuredPost ? (
                                <a class="news-featured-card" href={localizePath(featuredPost.path)}>
                                  {featuredPost.featuredImage && (
                                    <span class="news-featured-image">
                                      <img src={featuredPost.featuredImage.path} alt={featuredPost.title} loading="lazy">
                                      <span class="news-date-badge">{featuredPost.date}</span>
                                    </span>
                                  )}
                                  <span class="news-featured-title">{featuredPost.title}</span>
                                  {featuredPost.excerpt && (
                                    <span class="news-featured-excerpt">{featuredPost.excerpt}</span>
                                  )}
                                </a>
                              ) : (
                                <a class="news-featured-placeholder" href={localizePath(newsCategory.path)}>
                                  <span class="news-featured-icon" aria-hidden="true">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                      <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 12h10" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                  </span>
                                </a>
                              )}

                              {latestPosts.length > 0 && (
                                <ul class="news-latest-list">
                                  {latestPosts.map((post: any) => (
                                    <li>
                                      <a href={localizePath(post.path)}>
                                        <span class="news-date-badge">{post.date}</span>
                                        <span>{post.title}</span>
                                      </a>
                                    </li>
                                  ))}
                                </ul>
                              )}
                            </section>
                          )
                        })}
                      </div>
                    )}

                    {menuType === 'solution' && (
                      <div class="solutions-megamenu-inner">
                        <div class="solutions-megamenu-main">
                          <h2 class="solutions-megamenu-title">{getUITranslation(lang, 'megamenu.prefabDC')}</h2>
                          <div class="solutions-card-grid">
                            {item.children.map(solution => (
                              <a class="solutions-card" href={localizePath(solution.path)}>
                                <span class="solutions-card-image">
                                  {solution.featuredImage && (
                                    <img src={solution.featuredImage.path} alt={solution.title} loading="lazy">
                                  )}
                                </span>
                                <span class="solutions-card-title">{translateCategoryTitle(solution.title)}</span>
                                <span class="solutions-card-description">{(solution as any).postExcerpt || solution.excerpt || `Explore ${solution.title} solutions.`}</span>
                              </a>
                            ))}
                          </div>
                        </div>
                        <aside class="solutions-megamenu-sidebar">
                          <h2 class="solutions-megamenu-title">{getUITranslation(lang, 'megamenu.industries')}</h2>
                          <ul class="solutions-industry-list">
                            <li>{getUITranslation(lang, 'megamenu.industryTelecom')}</li>
                            <li>{getUITranslation(lang, 'megamenu.industryFinance')}</li>
                            <li>{getUITranslation(lang, 'megamenu.industryGovernment')}</li>
                            <li>{getUITranslation(lang, 'megamenu.industryColocation')}</li>
                          </ul>
                          <div class="solutions-custom-cta">
                            <span>{getUITranslation(lang, 'megamenu.customSolution')}</span>
                            <a href={contactUrl}>{getUITranslation(lang, 'megamenu.talkToExpert')}</a>
                          </div>
                        </aside>
                      </div>
                    )}

                    {menuType === 'product' && (
                      <div class="megamenu-inner">
                        {item.children.map(column => (
                          <div class="megamenu-column">
                            <a class="megamenu-heading" href={localizePath(column.path)}>
                              <span class="megamenu-heading-icon" aria-hidden="true">
                                {column.featuredImage ? (
                                  <img src={column.featuredImage.path} alt="" width="16" height="16">
                                ) : (
                                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <rect width="16" height="16" fill="#1a85e5"/>
                                  </svg>
                                )}
                              </span>
                              <span class="megamenu-heading-text">{translateCategoryTitle(column.title)}</span>
                            </a>

                            {column.children && (
                              <ul class="megamenu-list">
                                {column.children.map(child => (
                                  <li>
                                    <a href={localizePath(child.path)}>{translateCategoryTitle(child.title)}</a>
                                  </li>
                                ))}
                              </ul>
                            )}
                          </div>
                        ))}
                      </div>
                    )}
                  </div>
                </>
              )}
            </li>
          )
        })}
      </ul>
    </nav>

    <div class="header-actions">
      <div class="header-dropdown language-navigation">
        <button class="language-toggle" type="button" aria-expanded="false" aria-label="Language">
          <img class="globe-icon" src="/resources/globe-1.svg" alt="" width="22" height="22" aria-hidden="true">
        </button>
        <ul class="header-dropdown-panel language-panel">
          {languages.map(l => (
            <li>
              <a href={getLanguageUrl(l.slug)} aria-current={l.slug === lang ? 'true' : undefined}>
                <img src={l.flag.path} alt={l.name} width="18" height="12">
                <span>{l.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="header-dropdown header-search">
        <button class="header-icon-button header-search-toggle" type="button" aria-expanded="false" aria-label="Search">
          <img class="search-icon" src="/resources/MagnifyingGlass.svg" alt="" width="18" height="18" aria-hidden="true">
        </button>
        <div class="header-dropdown-panel search-panel">
          <form role="search" method="get" class="header-search-form" action={localizePath("/en/")}>
            <label class="screen-reader-text" for="header-search-field">Search for:</label>
            <input id="header-search-field" type="search" name="s" placeholder={getUITranslation(lang, 'common.searchPlaceholder')}>
            <button type="submit">Search</button>
          </form>
        </div>
      </div>

      <a class="header-contact-button" href={contactUrl}>
        {translateNav('Contact Us')}
      </a>
    </div>
  </div>
</header>

<!-- Mobile menu overlay -->
<div id="mobile-menu-overlay" class="mobile-menu-overlay">
  <div class="mobile-menu-sidebar">
    <div class="mobile-menu-header">
      <button class="mobile-menu-close" type="button" aria-label="Close menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <a class="mobile-menu-logo" href={localizePath("/en/")} rel="home" aria-label="Soeteck">
        <img src={logoUrl} alt="Soeteck" width="140" height="auto">
      </a>
    </div>
    <div class="mobile-menu-content">
      <nav class="mobile-nav" aria-label="Mobile menu">
        <ul class="mobile-nav-list">
          {mainNavigation.map(item => {
            const titleKey = item.title.toLowerCase()
            const isContact = titleKey === 'contact us'
            if (isContact) return null

            const hasChildren = !!(item.children && item.children.length)

            return (
              <li class={`mobile-menu-item${hasChildren ? ' mobile-has-submenu' : ''}`}>
                {hasChildren ? (
                  <div class="mobile-menu-toggle-item">
                    <a class="mobile-menu-parent-link" href={localizePath(item.path)}>{translateNav(item.title)}</a>
                    <button class="mobile-menu-toggle-button" type="button" aria-expanded="false" aria-label={`Toggle ${item.title} menu`}>
                      <svg class="mobile-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="m19.5 8.25l-7.5 7.5-7.5-7.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </button>
                  </div>
                ) : (
                  <a class="mobile-menu-link" href={localizePath(item.path)}>
                    {translateNav(item.title)}
                  </a>
                )}

                {hasChildren && (
                  <div class="mobile-submenu">
                    <div class="mobile-submenu-content">
                      {item.children.map(column => {
                        const hasGrandChildren = !!(column.children && column.children.length)

                        return (
                          <div class={`mobile-accordion-section${hasGrandChildren ? ' mobile-has-nested' : ''}`}>
                            <div class="mobile-accordion-toggle">
                              <a class="mobile-accordion-main-link" href={localizePath(column.path)}>{translateCategoryTitle(column.title)}</a>
                              {hasGrandChildren && (
                                <button class="mobile-accordion-toggle-button" type="button" aria-expanded="false" aria-label={`Toggle ${column.title} section`}>
                                  <svg class="mobile-accordion-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path d="m19.5 8.25l-7.5 7.5-7.5-7.5" stroke-linecap="round" stroke-linejoin="round"/>
                                  </svg>
                                </button>
                              )}
                            </div>

                            {hasGrandChildren && (
                              <div class="mobile-accordion-nested">
                                {column.children.map(child => {
                                  const hasGreatGrandChildren = !!(child.children && child.children.length)

                                  return hasGreatGrandChildren ? (
                                    <div class="mobile-accordion-section mobile-has-nested">
                                      <div class="mobile-accordion-toggle mobile-accordion-toggle-link-style">
                                        <a class="mobile-accordion-main-link" href={localizePath(child.path)}>{translateCategoryTitle(child.title)}</a>
                                        <button class="mobile-accordion-toggle-button" type="button" aria-expanded="false" aria-label={`Toggle ${child.title} section`}>
                                          <svg class="mobile-accordion-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <path d="m19.5 8.25l-7.5 7.5-7.5-7.5" stroke-linecap="round" stroke-linejoin="round"/>
                                          </svg>
                                        </button>
                                      </div>
                                      <div class="mobile-accordion-nested">
                                        {child.children.map(grandChild => (
                                          <a href={localizePath(grandChild.path)} class="mobile-accordion-sub-link">
                                            {grandChild.title}
                                          </a>
                                        ))}
                                      </div>
                                    </div>
                                  ) : (
                                    <a href={localizePath(child.path)} class="mobile-accordion-sub-link">
                                      {child.title}
                                    </a>
                                  )
                                })}
                              </div>
                            )}
                          </div>
                        )
                      })}
                    </div>
                  </div>
                )}
              </li>
            )
          })}
        </ul>
      </nav>
      <div class="mobile-menu-footer">
        <div class="mobile-lang-switcher">
          <span class="mobile-lang-title">{getUITranslation(lang, 'common.language')}</span>
          <div class="mobile-lang-options">
            {languages.map(l => (
              <a class={`mobile-lang-option${l.slug === lang ? ' active' : ''}`} href={getLanguageUrl(l.slug)}>
                <img src={l.flag.path} alt={l.name} width="18" height="12">
                <span>{l.name}</span>
              </a>
            ))}
          </div>
        </div>
        <a class="mobile-contact-btn" href={contactUrl}>
          {translateNav('Contact Us')}
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Mobile search overlay -->
<div id="mobile-search-overlay" class="mobile-search-overlay">
  <div class="mobile-search-sidebar">
    <div class="mobile-menu-header">
      <button class="mobile-search-close" type="button" aria-label="Close search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="mobile-search-title">{getUITranslation(lang, 'common.search')}</div>
    </div>
    <div class="mobile-search-content">
      <form role="search" method="get" class="mobile-search-form" action={localizePath("/en/")}>
        <label class="screen-reader-text" for="mobile-search-field">Search for:</label>
        <input id="mobile-search-field" type="search" name="s" placeholder={getUITranslation(lang, 'common.searchPlaceholder')} class="mobile-search-input">
        <button type="submit" aria-label="Search" class="mobile-search-submit">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" aria-hidden="true">
            <path d="m21 21l-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>

<script is:inline>
// Header navigation interactions
document.addEventListener('DOMContentLoaded', function() {
  const header = document.querySelector('.site-header')
  if (!header) return

  // Mobile menu toggle
  const menuToggle = header.querySelector('.menu-toggle')
  const mobileMenuOverlay = document.getElementById('mobile-menu-overlay')
  const mobileMenuClose = document.querySelector('.mobile-menu-close')

  function toggleMobileMenu() {
    const isOpen = mobileMenuOverlay.classList.toggle('is-open')
    menuToggle.classList.toggle('is-open', isOpen)
    document.body.classList.toggle('mobile-menu-open', isOpen)
  }

  if (menuToggle && mobileMenuOverlay) {
    menuToggle.addEventListener('click', toggleMobileMenu)
    if (mobileMenuClose) mobileMenuClose.addEventListener('click', toggleMobileMenu)
    mobileMenuOverlay.addEventListener('click', function(e) {
      if (e.target === mobileMenuOverlay) toggleMobileMenu()
    })
  }

  // Mobile search toggle
  const searchToggle = header.querySelector('.header-search-toggle')
  const mobileSearchOverlay = document.getElementById('mobile-search-overlay')
  const mobileSearchClose = document.querySelector('.mobile-search-close')

  function toggleMobileSearch() {
    const isOpen = mobileSearchOverlay.classList.toggle('is-open')
    document.body.classList.toggle('mobile-search-open', isOpen)
    if (isOpen) {
      document.getElementById('mobile-search-field')?.focus()
    }
  }

  if (searchToggle && mobileSearchOverlay) {
    searchToggle.addEventListener('click', function(e) {
      if (window.innerWidth <= 991) {
        e.preventDefault()
        toggleMobileSearch()
      }
    })
    mobileSearchClose.addEventListener('click', toggleMobileSearch)
    mobileSearchOverlay.addEventListener('click', function(e) {
      if (e.target === mobileSearchOverlay) toggleMobileSearch()
    })
  }

  // Mobile accordion toggles
  header.querySelectorAll('.mobile-menu-toggle-button, .mobile-accordion-toggle-button').forEach(button => {
    button.addEventListener('click', function() {
      const isExpanded = this.getAttribute('aria-expanded') === 'true'
      this.setAttribute('aria-expanded', isExpanded ? 'false' : 'true')

      const section = this.closest('.mobile-menu-item, .mobile-accordion-section')
      if (section) {
        section.classList.toggle('is-open', !isExpanded)
      }
    })
  })

  // Desktop dropdown interactions
  if (window.innerWidth >= 992) {
    const dropdownToggles = header.querySelectorAll('.language-toggle, .header-search-toggle')
    const dropdownPanels = header.querySelectorAll('.header-dropdown-panel')

    dropdownToggles.forEach(toggle => {
      toggle.addEventListener('click', function(e) {
        e.preventDefault()
        const dropdown = this.closest('.header-dropdown')
        if (!dropdown) return

        const isOpen = dropdown.classList.toggle('dropdown-open')
        this.setAttribute('aria-expanded', isOpen ? 'true' : 'false')

        // Close other dropdowns
        dropdownToggles.forEach(otherToggle => {
          if (otherToggle !== toggle) {
            otherToggle.setAttribute('aria-expanded', 'false')
            otherToggle.closest('.header-dropdown')?.classList.remove('dropdown-open')
          }
        })
      })
    })

    // Close dropdowns when clicking outside
    document.addEventListener('click', function(e) {
      if (!header.contains(e.target)) {
        dropdownToggles.forEach(toggle => {
          toggle.setAttribute('aria-expanded', 'false')
          toggle.closest('.header-dropdown')?.classList.remove('dropdown-open')
        })
      }
    })
  }
})
</script>
