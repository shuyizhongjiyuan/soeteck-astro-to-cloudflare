---
import type { PageImage } from '@/lib/page-adapter';

interface Props {
  images: PageImage[];
}

const { images } = Astro.props;
---
<div class="factory-wall" aria-label="SOETECK factory proof photos">
  {images.slice(0, 5).map((image) => (
    <a class="factory-wall__link" href={image.path} data-soeteck-lightbox data-lightbox-src={image.path} data-lightbox-group="about-factory" aria-label={image.alt || 'View SOETECK factory photo'}>
      <img class="factory-wall__image" src={image.path} alt={image.alt} loading="lazy" />
    </a>
  ))}
</div>

<style>
  .factory-wall {
    position: relative;
    min-height: 520px;
  }

  .factory-wall__link {
    position: absolute;
    display: block;
    min-width: 0;
    overflow: hidden;
    border-radius: 10px;
    box-shadow: 0 20px 46px rgba(15, 23, 42, 0.16);
  }

  .factory-wall__link:nth-child(1) {
    inset: 6% auto auto 0;
    width: 68%;
    height: 58%;
    z-index: 10;
  }

  .factory-wall__link:nth-child(2) {
    top: 0;
    right: 3%;
    width: 38%;
    height: 34%;
    z-index: 3;
  }

  .factory-wall__link:nth-child(3) {
    right: 0;
    bottom: 10%;
    width: 46%;
    height: 42%;
    z-index: 4;
  }

  .factory-wall__link:nth-child(4) {
    left: 8%;
    bottom: 0;
    width: 34%;
    height: 30%;
    z-index: 5;
  }

  .factory-wall__link:nth-child(5) {
    left: 46%;
    bottom: -10%;
    width: 28%;
    height: 24%;
    z-index: 6;
  }

  .factory-wall__image {
    width: 100%;
    height: 100%;
    border-radius: 10px;
    object-fit: cover;
  }

  @media (prefers-reduced-motion: no-preference) {
    .factory-wall__link {
      transition: transform 240ms ease, box-shadow 240ms ease, filter 240ms ease;
    }

    .factory-wall__image {
      transition: transform 240ms ease;
    }

    .factory-wall:hover .factory-wall__link {
      filter: saturate(0.92) brightness(0.96);
    }

    .factory-wall__link:hover {
      transform: translateY(-4px) scale(1.012);
      filter: saturate(1.04) brightness(1.015);
      box-shadow: 0 22px 50px rgba(15, 23, 42, 0.2);
    }

    .factory-wall__link:hover .factory-wall__image {
      transform: scale(1.018);
    }
  }

  @media (max-width: 768px) {
    .factory-wall {
      min-height: 420px;
    }
  }

  @media (max-width: 640px) {
    .factory-wall {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      min-height: 0;
    }

    .factory-wall__link:nth-child(n) {
      position: static;
      width: 100%;
      height: auto;
      aspect-ratio: 4 / 3;
    }

    .factory-wall__link:first-child {
      grid-column: 1 / -1;
      aspect-ratio: 16 / 9;
    }

    .factory-wall__image:nth-child(n) {
      height: 100%;
    }
  }
</style>
