  /* === Per-page and Sort (main.js lines 275-299) === */
  var defaultPerPageValue = config.defaultPerPage || 5;
  var allowedPerPageValues = config.allowedPerPage || [5, 10, 20, 50, 100];

  function updatePerPageSelect() {
    if (!perPageSelect) return;
    var isDefault = perPage === defaultPerPageValue;
    var options = '<option value=""' + (isDefault ? ' selected' : '') + (isDefault ? ' disabled' : '') + (isDefault ? ' hidden' : '') + '>' + (labels.default || 'Default') + '</option>';
    allowedPerPageValues.forEach(function(pp) {
      options += '<option value="' + pp + '"' + (perPage === pp ? ' selected' : '') + '>' + pp + '</option>';
    });
    perPageSelect.innerHTML = options;
  }

  function updateSortSelect() {
    if (!sortSelect) return;
    var isDefault = sort === 'default';
    var options = '<option value="default"' + (isDefault ? ' selected' : '') + (isDefault ? ' disabled' : '') + (isDefault ? ' hidden' : '') + '>' + (labels.orderBy || 'Order by') + '</option>';
    options += '<option value="featured"' + (sort === 'featured' ? ' selected' : '') + '>' + (labels.featured || 'Featured') + '</option>';
    options += '<option value="latest"' + (sort === 'latest' ? ' selected' : '') + '>' + (labels.latest || 'Latest') + '</option>';
    sortSelect.innerHTML = options;
  }

  if (perPageSelect) {
    perPageSelect.addEventListener('change', function() {
