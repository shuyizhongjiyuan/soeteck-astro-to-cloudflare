  /* === Mobile Filter Panel (main.js lines 181-206) === */
  var mobileToggle = document.querySelector('.soeteck-product-filters__mobile-toggle');
  var filterPanel = document.getElementById('soeteck-product-filters-panel');
  var filterClose = document.querySelector('.soeteck-product-filters__panel-close');
  var filterOverlay = document.querySelector('.soeteck-product-filters__overlay');

  function closeMobilePanel() {
