---
interface Props {
  title: string;
  path: string;
  image?: { path: string; alt?: string } | null;
}

const { title, path, image } = Astro.props;
---
<section class="home-hero">
  <div class="hero-inner">
    <div class="hero-copy">
      <p class="soeteck-eyebrow">Soeteck Power & Cooling</p>
      <h1>{title}</h1>
      <p class="hero-lead">Professional digital power, cooling, and data center infrastructure solutions for mission-critical environments.</p>
      <div class="hero-actions">
        <a class="primary-cta" href="/en/products/critical-power/">Explore Products</a>
        <a class="secondary-cta" href="/en/contact-us/">Talk to an Expert</a>
      </div>
      <p class="route-note">PoC route: {path}</p>
    </div>

    {image && (
      <div class="hero-media">
        <img src={image.path} alt={image.alt ?? ''} loading="eager" />
      </div>
    )}
  </div>
</section>

<style>
  .home-hero {
    background:
      radial-gradient(circle at 78% 22%, rgba(26, 133, 229, 0.18), transparent 32%),
      linear-gradient(135deg, #f8fbff 0%, #edf5ff 52%, #ffffff 100%);
    border-bottom: 1px solid var(--soeteck-border-soft);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
    align-items: center;
    width: min(var(--soeteck-container-wide), calc(100% - (var(--soeteck-gutter) * 2)));
    min-height: clamp(520px, 70vh, 760px);
    margin-inline: auto;
    gap: clamp(32px, 6vw, 88px);
    padding-block: clamp(64px, 8vw, 112px);
  }

  .hero-copy h1 {
    max-width: 680px;
    margin: 0;
    color: var(--soeteck-navy);
    font-size: clamp(3.1rem, 6.8vw, 6.4rem);
    font-weight: 800;
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .hero-lead {
    max-width: 620px;
    margin: 26px 0 0;
    color: var(--soeteck-text-soft);
    font-size: clamp(1.05rem, 1.4vw, 1.32rem);
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .primary-cta,
  .secondary-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
  }

  .primary-cta {
    background: var(--soeteck-primary);
    color: #fff;
    box-shadow: 0 16px 34px rgba(26, 133, 229, 0.26);
  }

  .secondary-cta {
    border: 1px solid var(--soeteck-border);
    background: #fff;
    color: var(--soeteck-navy);
  }

  .route-note {
    margin-top: 22px;
    color: var(--soeteck-muted);
    font-size: 0.86rem;
  }

  .hero-media {
    position: relative;
    border-radius: 28px;
    background: linear-gradient(135deg, #e8f3ff 0%, #d9ebff 100%);
    box-shadow: var(--soeteck-shadow-card);
    overflow: hidden;
  }

  .hero-media::before {
    content: '';
    display: block;
    aspect-ratio: 1.22;
  }

  .hero-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 991px) {
    .hero-inner {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-block: 56px;
    }

    .hero-copy h1 {
      font-size: clamp(2.7rem, 14vw, 4.6rem);
    }
  }
</style>
