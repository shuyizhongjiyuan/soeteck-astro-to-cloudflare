---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AboutPage from '@/components/about/AboutPage.astro';
import ArticleSinglePage from '@/components/article-single/ArticleSinglePage.astro';
import GenericPocPage from '@/components/poc/GenericPocPage.astro';
import HomeHero from '@/components/HomeHero.astro';
import NewsReleasesPage from '@/components/news-releases/NewsReleasesPage.astro';
import ProductCategoryPage from '@/components/product-category/ProductCategoryPage.astro';
import ProductSinglePage from '@/components/product-single/ProductSinglePage.astro';
import { fetchPocRoutes, fetchRouteContent } from '@/lib/content-api';
import { adaptPage } from '@/lib/page-adapter';

const languages = ['en', 'zh', 'ru', 'pt', 'es'];

export async function getStaticPaths() {
  const routes = await fetchPocRoutes();
  const langs = ['en', 'zh', 'ru', 'pt', 'es'];

  // 为每种语言 × 每个路由生成静态路径
  // API 路由路径格式: /en/solutions/liquid-cooling/
  // 需要替换语言前缀为目标语言
  return langs.flatMap(lang =>
    routes.map((route) => {
      // 替换语言前缀: /en/xxx → /{lang}/xxx
      const pathWithLang = route.path.replace(/^\/en\//, `/${lang}/`);
      // 移除前导斜杠和尾部斜杠，生成 params
      const pathParam = pathWithLang.replace(/^\//, '').replace(/\/$/, '') || undefined;

      return {
        params: { path: pathParam },
        props: { route, lang },
      };
    })
  );
}

const { route, lang } = Astro.props;

let page;
try {
  const content = await fetchRouteContent(route, lang);
  page = adaptPage(content);
} catch (e) {
  // API 请求失败时渲染降级页面
  page = {
    id: null,
    kind: 'generic' as const,
    routeType: route.routeType,
    routePath: route.path,
    language: lang,
    title: 'Error loading page',
    seo: { title: 'Error', canonical: '', robots: 'noindex' },
    breadcrumbs: [{ label: 'Home', path: `/${lang}/` }],
    heroImage: null,
    contentHtml: '',
    media: [],
    article: null,
    articles: [],
    featuredArticles: [],
    source: {} as any,
  };
}

// 使用 API 返回的真实 localizedPaths（包含各语言实际路径和状态）
const localizedPaths: Record<string, { path: string | null; status: string }> | undefined = page.source?.route?.localizedPaths;
// 去掉语言前缀的路径，用于 canonical URL
const pathWithoutLang = route.path.replace(/^\/[a-z]{2}\//, '/');
---
<BaseLayout
  lang={lang}
  title={page.seo.title}
  canonical={`https://soeteck.com/${lang}${pathWithoutLang}`}
  robots={page.seo.robots}
  localizedPaths={localizedPaths}
>
  {page.kind === 'home' ? (
    <>
      <HomeHero title="We Master Power and Cooling" path={page.routePath} image={page.heroImage} />
      <main class="home-content">
        <div class="soeteck-container intro-grid">
          <section>
            <p class="soeteck-eyebrow">Architecture PoC</p>
            <h2>Content API powered Astro rendering</h2>
            <p>This page is generated by Astro from the Soeteck Content API while preserving the current URL, canonical policy, and clean resources path strategy.</p>
          </section>
          <section class="home-content-card">
            <h3>Current validation</h3>
            <ul>
              <li>Static route generated from fixture.</li>
              <li>SEO title and canonical from Content API.</li>
              <li>Media normalized to <code>/resources/</code>.</li>
            </ul>
          </section>
        </div>
      </main>
    </>
  ) : page.kind === 'about' ? (
    <AboutPage page={page} lang={lang} />
  ) : page.kind === 'newsReleases' ? (
    <NewsReleasesPage page={page} lang={lang} />
  ) : page.kind === 'productCategory' ? (
    <ProductCategoryPage page={page} lang={lang} />
  ) : page.kind === 'productSingle' ? (
    <ProductSinglePage page={page} lang={lang} />
  ) : page.kind === 'articleSingle' ? (
    <ArticleSinglePage page={page} lang={lang} />
  ) : (
    <GenericPocPage page={page} lang={lang} />
  )}
</BaseLayout>

<style>
  .home-content {
    padding: var(--soeteck-section-y-sm) 0 var(--soeteck-section-y);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 380px;
    gap: var(--soeteck-card-gap);
    align-items: start;
  }

  .intro-grid h2 {
    max-width: 720px;
    margin: 0;
    color: var(--soeteck-navy);
    font-size: var(--soeteck-heading-lg);
    letter-spacing: -0.04em;
  }

  .intro-grid p {
    max-width: 760px;
    margin-top: 18px;
    color: var(--soeteck-text-soft);
    font-size: var(--soeteck-text-lg);
  }

  .home-content-card {
    border: 1px solid var(--soeteck-border-soft);
    border-radius: var(--soeteck-radius-lg);
    background: #fff;
    box-shadow: var(--soeteck-shadow);
    padding: 24px;
  }

  .home-content-card ul {
    margin: 16px 0 0;
    padding-left: 20px;
    color: var(--soeteck-text-soft);
  }

  @media (max-width: 991px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
