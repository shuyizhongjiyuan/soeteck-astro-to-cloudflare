---
import type { AdaptedPage } from '@/lib/page-adapter';
import type { ContentApiProductCard, ContentApiArchiveConfig, ContentApiFilterGroup } from '@/lib/content-api';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getUITranslation } from '@/lib/translations';

interface Props {
  page: AdaptedPage;
  lang?: string;
}

const { page, lang = 'en' } = Astro.props;
const source = page.source;
const category = source.category;
const products: ContentApiProductCard[] = source.products ?? [];
const siblings = source.siblings ?? [];
const bannerImage = source.bannerImage ? { path: source.bannerImage.path, alt: source.bannerImage.alt ?? '' } : page.heroImage;
const archiveConfig: ContentApiArchiveConfig | null = source.archiveConfig ?? null;

const title = category?.name ?? page.title;
const description = category?.description ? category.description.replace(/<[^>]*>/g, '').trim() : '';
const filters: ContentApiFilterGroup[] = archiveConfig?.filters ?? [];
const introBlocks = archiveConfig?.introBlocks ?? [];
const defaultPerPage = archiveConfig?.defaultPerPage ?? 5;
const allowedPerPage = archiveConfig?.allowedPerPage ?? [5, 10, 20, 50, 100];
const defaultSort = archiveConfig?.defaultSort ?? 'default';
const hasFilters = filters.length > 0;

// Filter group order matches WP: category, application, capacity, installation
const filterGroupOrder = ['category', 'application', 'capacity', 'installation'];
const orderedFilters = filterGroupOrder
  .map(key => filters.find(f => f.key === key))
  .filter((f): f is ContentApiFilterGroup => !!f);

// Translations for product card buttons (must be defined before configJson)
const salesContactLabel = getUITranslation(lang, 'product.salesContact');
const viewDetailsLabel = getUITranslation(lang, 'product.viewDetails');
const modelsLabel = getUITranslation(lang, 'product.models');
const showMoreLabel = getUITranslation(lang, 'product.showMore');
const showLessLabel = getUITranslation(lang, 'product.showLess');
const localizedContactUrl = lang === 'en' ? '/en/contact-us/' : `/${lang}/contact-us/`;

// Archive UI translations
const filtersLabel = getUITranslation(lang, 'archive.filters');
const clearFiltersLabel = getUITranslation(lang, 'archive.clearFilters');
const applyFiltersLabel = getUITranslation(lang, 'archive.applyFilters');
const clearAllLabel = getUITranslation(lang, 'archive.clearAll');
const resultsPerPageLabel = getUITranslation(lang, 'archive.resultsPerPage');
const orderByLabel = getUITranslation(lang, 'archive.orderBy');
const featuredLabel = getUITranslation(lang, 'archive.featured');
const latestLabel = getUITranslation(lang, 'archive.latest');
const defaultLabel = getUITranslation(lang, 'archive.default');
const applyLabel = getUITranslation(lang, 'archive.apply');
const noResultsLabel = getUITranslation(lang, 'archive.noResults');
const showingAllLabel = getUITranslation(lang, 'archive.showingAll');
const showingRangeLabel = getUITranslation(lang, 'archive.showingRange');

// Prepare JSON for client-side filtering
const productsJson = JSON.stringify(products);
const configJson = JSON.stringify({
  filters: orderedFilters,
  defaultPerPage,
  allowedPerPage,
  defaultSort,
  contactUrl: localizedContactUrl,
  labels: {
    salesContact: salesContactLabel,
    viewDetails: viewDetailsLabel,
    models: modelsLabel,
    showMore: showMoreLabel,
    showLess: showLessLabel,
    filters: filtersLabel,
    clearFilters: clearFiltersLabel,
    applyFilters: applyFiltersLabel,
    clearAll: clearAllLabel,
    resultsPerPage: resultsPerPageLabel,
    orderBy: orderByLabel,
    featured: featuredLabel,
    latest: latestLabel,
    default: defaultLabel,
    apply: applyLabel,
    noResults: noResultsLabel,
    showingAll: showingAllLabel,
    showingRange: showingRangeLabel,
  },
});
---

<div id="primary" class="content-area soeteck-product-category-archive">
  <main id="main" class="site-main">
    <section class="soeteck-product-cat-hero">
      {bannerImage && (
        <img
          class="soeteck-product-cat-hero__image"
          src={bannerImage.path}
          alt={bannerImage.alt}
          fetchpriority="high"
          loading="eager"
        />
      )}
      <div class="soeteck-product-cat-hero__overlay"></div>
      <div class="soeteck-container soeteck-product-cat-hero__breadcrumbs">
        <Breadcrumbs items={page.breadcrumbs} class="soeteck-breadcrumbs--hero" lang={lang} />
      </div>
      <div class="soeteck-container soeteck-product-cat-hero__content">
        <h1 class="soeteck-page-title soeteck-product-cat-hero__title">{title}</h1>
        {description && (
          <p class="soeteck-product-cat-hero__lead">{description}</p>
        )}
      </div>
    </section>

    <div class="soeteck-product-category-body">
      <div class="soeteck-container soeteck-product-category-layout">
        <aside class="soeteck-product-filters" aria-label="Product filters">
          <div class="soeteck-product-filters__mobile-bar">
            <button class="soeteck-product-filters__mobile-toggle" type="button" aria-expanded="false" aria-controls="soeteck-product-filters-panel">
              {filtersLabel}
            </button>
          </div>

          {siblings.length > 0 && (
            <div class="soeteck-product-category-switcher">
              <button class="soeteck-product-category-switcher__toggle" type="button" aria-expanded="false" aria-controls="soeteck-product-category-switcher-panel">
                <span>{title}</span>
                <span class="soeteck-product-category-switcher__chevron" aria-hidden="true"></span>
              </button>
              <div id="soeteck-product-category-switcher-panel" class="soeteck-product-category-switcher__panel">
                {siblings.map((sibling) => {
                  // 用 slug 匹配（语言无关），避免路径前缀 /en/ vs /zh/ 导致匹配失败
                  const isCurrent = sibling.slug === (category?.slug ?? '');
                  return isCurrent ? (
                    <span class="soeteck-product-category-switcher__item is-current" aria-current="page">
                      {category?.name ?? title}
                    </span>
                  ) : (
                    <a class="soeteck-product-category-switcher__item" href={sibling.path} target="_blank" rel="noopener noreferrer">
                      {sibling.name}
                    </a>
                  );
                })}
              </div>
            </div>
          )}

          {hasFilters && (
            <div id="soeteck-product-filters-panel" class="soeteck-product-filters__panel">
              <div class="soeteck-product-filters__panel-header">
                <span>{filtersLabel}</span>
                <button class="soeteck-product-filters__panel-close" type="button" aria-label="Close filters"></button>
              </div>

              <div class="soeteck-product-filters__actions">
                <a class="soeteck-product-filters__clear-action" href={page.routePath} data-has-active-filters="false">{clearFiltersLabel}</a>
                <button class="soeteck-button soeteck-button-primary soeteck-product-filters__submit" type="submit" form="soeteck-product-filters-form">
                  {applyFiltersLabel}
                </button>
              </div>

              <form id="soeteck-product-filters-form" class="soeteck-product-filters__form">
                <div class="soeteck-product-filters__groups">
                  {orderedFilters.map((group, groupIndex) => {
                    const isOpen = group.key === 'category' || groupIndex === 0;
                    const isLong = group.terms.length > 8;
                    const panelId = `soeteck-filter-panel-${group.key}`;
                    return (
                      <div class={`soeteck-filter-group${isOpen ? ' is-open' : ''}${isLong ? ' is-long' : ''}`} role="group" aria-labelledby={`soeteck-filter-label-${group.key}`}>
                        <button class="soeteck-filter-group__toggle" type="button" aria-expanded={isOpen ? 'true' : 'false'} aria-controls={panelId} id={`soeteck-filter-label-${group.key}`}>
                          <span class="soeteck-filter-group__label">{group.label}</span>
                          <span class="soeteck-filter-group__chevron" aria-hidden="true"></span>
                        </button>
                        <div id={panelId} class="soeteck-filter-group__panel">
                          <div class="soeteck-filter-group__options">
                            {group.terms.map((term) => (
                              <label class="soeteck-filter-option">
                                <input
                                  type="checkbox"
                                  name={`${group.queryArg}[]`}
                                  value={String(term.id)}
                                  data-filter-group={group.key}
                                  data-filter-label={term.name}
                                />
                                <span>{term.name}</span>
                              </label>
                            ))}
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </form>
            </div>
          )}

          <button class="soeteck-product-filters__overlay" type="button" aria-label="Close filters"></button>
        </aside>

        <div class="soeteck-product-results" data-products={productsJson} data-config={configJson}>
          <div class="soeteck-active-filters" id="active-filters" style="display: none;"></div>

          {introBlocks.length > 0 && (
            <div class="soeteck-product-results__intro">
              <p>
                {introBlocks.map((block, index) => (
                  <>
                    {index > 0 && <br />}
                    {block.prefix && <strong>{block.prefix}</strong>}
                    {block.text ?? ''}
                  </>
                ))}
              </p>
            </div>
          )}

          <div class="soeteck-product-toolbar">
            <div class="soeteck-product-toolbar__count">
              <p id="product-result-count">Showing {products.length} of {products.length} results</p>
            </div>

            <div class="soeteck-product-toolbar__controls">
              <form class="soeteck-product-toolbar__form" onsubmit="return false;">
                <label class="soeteck-product-toolbar__label soeteck-product-toolbar__label--per-page">
                  <span class="screen-reader-text">{resultsPerPageLabel}</span>
                  <select id="product-per-page" name="per_page" class="soeteck-product-toolbar__select" aria-label={resultsPerPageLabel}>
                    <option value="" selected disabled hidden>{resultsPerPageLabel}</option>
                    {allowedPerPage.map((pp) => (
                      <option value={String(pp)}>{String(pp)}</option>
                    ))}
                  </select>
                </label>

                <label class="soeteck-product-toolbar__label">
                  <span class="screen-reader-text">{orderByLabel}</span>
                  <select id="product-sort" name="sort" class="soeteck-product-toolbar__select" aria-label={orderByLabel}>
                    <option value="default" selected disabled hidden>{orderByLabel}</option>
                    <option value="featured">{featuredLabel}</option>
                    <option value="latest">{latestLabel}</option>
                  </select>
                </label>

                <button class="soeteck-product-toolbar__submit" type="submit">{applyLabel}</button>
              </form>
            </div>
          </div>

          <div id="product-grid-container">
            <div class="soeteck-product-list">
              {products.map((product) => {
                const images = product.gallery && product.gallery.length > 0
                  ? product.gallery
                  : (product.featuredImage ? [product.featuredImage] : []);
                const hasMultiple = images.length > 1;
                return (
                  <article class="soeteck-product-list-item" data-product-id={product.id}>
                    <div class="soeteck-product-list-card">
                      <div class="soeteck-product-list-card__media soeteck-product-list-card__gallery" role="group" aria-label={product.title}>
                        {images.length > 0 && (
                          <>
                            <span class="soeteck-product-list-card__gallery-viewport">
                              <span class="soeteck-product-list-card__gallery-track">
                                {images.map((img, i) => (
                                  <span class={`soeteck-product-list-card__gallery-slide${i === 0 ? ' is-active' : ''}`} data-gallery-slide={String(i)}>
                                    <img src={img.path} alt={img.alt || product.title} loading={i === 0 ? 'eager' : 'lazy'} />
                                  </span>
                                ))}
                              </span>
                            </span>
                            {hasMultiple && (
                              <span class="soeteck-product-list-card__media-dots" aria-label="Product gallery images">
                                {images.map((_, i) => (
                                  <button class={i === 0 ? 'is-active' : ''} type="button" data-gallery-dot={String(i)} aria-label={`Show image ${i + 1}`} {...(i === 0 ? { 'aria-current': 'true' } : {})}></button>
                                ))}
                              </span>
                            )}
                          </>
                        )}
                      </div>
                      <div class="soeteck-product-list-card__content">
                        <h3 class="soeteck-card-title soeteck-product-list-card__title">
                          <a href={product.path} target="_blank" rel="noopener noreferrer">{product.title}</a>
                        </h3>
                        {product.excerpt && (
                          <p class="soeteck-product-list-card__excerpt">{product.excerpt}</p>
                        )}
                      </div>
                      <div class="soeteck-product-list-card__actions">
                        <a class="soeteck-product-list-card__button soeteck-product-list-card__button-primary" href={localizedContactUrl}>{salesContactLabel}</a>
                        <a class="soeteck-product-list-card__button" href={product.path} target="_blank" rel="noopener noreferrer">{viewDetailsLabel}</a>
                        {product.type === 'variable' && (
                          <button class="soeteck-product-list-card__button show-variations" type="button" data-target={`variations-${product.id}`} aria-controls={`variations-${product.id}`} aria-expanded="false">{modelsLabel}</button>
                        )}
                      </div>
                    </div>
                    {product.variationsTable && (
                      <div class="soeteck-product-list-item__models">
                        <div class="variations-table" id={`variations-${product.id}`}>
                          <table>
                            <thead><tr>{product.variationsTable.headers.map((h) => <th>{h}</th>)}</tr></thead>
                            <tbody>
                              {product.variationsTable.rows.map((row, i) => (
                                <tr class={`variation-row${i >= 10 ? ' variation-row--extra' : ''}`}>
                                  {row.map((cell) => <td>{cell}</td>)}
                                </tr>
                              ))}
                            </tbody>
                          </table>
                          {product.variationsTable.hasMore && (
                            <div class="toggle-variations-wrap">
                              <button class="toggle-variations" data-product-id={String(product.id)}>{showMoreLabel}</button>
                            </div>
                          )}
                        </div>
                      </div>
                    )}
                  </article>
                );
              })}
            </div>
          </div>

          <div id="product-pagination"></div>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
(function() {
  'use strict';

  var resultsEl = document.querySelector('.soeteck-product-results');
  if (!resultsEl) return;

  var allProducts = JSON.parse(resultsEl.getAttribute('data-products') || '[]');
  var config = JSON.parse(resultsEl.getAttribute('data-config') || '{}');
  var filterGroups = config.filters || [];
  var perPage = config.defaultPerPage || 5;
  var sort = config.defaultSort || 'default';
  var contactUrl = config.contactUrl || '/en/contact-us/';
  var labels = config.labels || {};
  var salesContactLabel = labels.salesContact || 'Sales Contact';
  var viewDetailsLabel = labels.viewDetails || 'View Details';
  var modelsLabel = labels.models || 'Models';
  var showMoreLabel = labels.showMore || 'Show more';
  var showLessLabel = labels.showLess || 'Show less';
  var currentPage = 1;

  var activeFilters = {};
  filterGroups.forEach(function(g) { activeFilters[g.key] = []; });

  var gridContainer = document.getElementById('product-grid-container');
  var paginationEl = document.getElementById('product-pagination');
  var resultCountEl = document.getElementById('product-result-count');
  var activeFiltersEl = document.getElementById('active-filters');
  var perPageSelect = document.getElementById('product-per-page');
  var sortSelect = document.getElementById('product-sort');
  var filtersContainer = document.querySelector('.soeteck-product-filters');

  function getFilteredProducts() {
    var filtered = allProducts.filter(function(product) {
      return filterGroups.every(function(group) {
        var selected = activeFilters[group.key] || [];
        if (selected.length === 0) return true;
        return selected.some(function(termId) {
          return product.tagIds && product.tagIds.some(function(id) { return String(id) === String(termId); });
        });
      });
    });

    if (sort === 'featured') {
      filtered.sort(function(a, b) { return (b.isFeatured ? 1 : 0) - (a.isFeatured ? 1 : 0); });
    } else if (sort === 'latest') {
      filtered.sort(function(a, b) { return new Date(b.date || 0) - new Date(a.date || 0); });
    }

    return filtered;
  }

  function renderCard(product) {
    var images = (product.gallery && product.gallery.length > 0)
      ? product.gallery
      : (product.featuredImage ? [product.featuredImage] : []);
    var hasMultiple = images.length > 1;

    var galleryHtml = '';
    if (images.length > 0) {
      var slidesHtml = images.map(function(img, i) {
        return '<span class="soeteck-product-list-card__gallery-slide' + (i === 0 ? ' is-active' : '') + '" data-gallery-slide="' + i + '">' +
          '<img src="' + img.path + '" alt="' + (img.alt || product.title) + '" loading="' + (i === 0 ? 'eager' : 'lazy') + '">' +
          '</span>';
      }).join('');

      var dotsHtml = '';
      if (hasMultiple) {
        dotsHtml = '<span class="soeteck-product-list-card__media-dots" aria-label="Product gallery images">' +
          images.map(function(_, i) {
            return '<button class="' + (i === 0 ? 'is-active' : '') + '" type="button" data-gallery-dot="' + i + '" aria-label="Show image ' + (i + 1) + '"' + (i === 0 ? ' aria-current="true"' : '') + '></button>';
          }).join('') +
          '</span>';
      }

      galleryHtml = '<span class="soeteck-product-list-card__gallery-viewport"><span class="soeteck-product-list-card__gallery-track">' +
        slidesHtml + '</span></span>' + dotsHtml;
    }

    var actionsHtml = '<a class="soeteck-product-list-card__button soeteck-product-list-card__button-primary" href="' + contactUrl + '">' + salesContactLabel + '</a>' +
      '<a class="soeteck-product-list-card__button" href="' + product.path + '" target="_blank" rel="noopener noreferrer">' + viewDetailsLabel + '</a>';
    if (product.type === 'variable') {
      actionsHtml += '<button class="soeteck-product-list-card__button show-variations" type="button" data-target="variations-' + product.id + '" aria-controls="variations-' + product.id + '" aria-expanded="false">' + modelsLabel + '</button>';
    }

    var modelsHtml = '';
    if (product.variationsTable) {
      var vt = product.variationsTable;
      var thHtml = vt.headers.map(function(h) { return '<th>' + h + '</th>'; }).join('');
      var trHtml = vt.rows.map(function(row, i) {
        var cls = 'variation-row' + (i >= 10 ? ' variation-row--extra' : '');
        var tdHtml = row.map(function(cell) { return '<td>' + cell + '</td>'; }).join('');
        return '<tr class="' + cls + '">' + tdHtml + '</tr>';
      }).join('');
      var moreHtml = vt.hasMore
        ? '<div class="toggle-variations-wrap"><button class="toggle-variations" data-product-id="' + product.id + '">' + showMoreLabel + '</button></div>'
        : '';
      modelsHtml = '<div class="soeteck-product-list-item__models">' +
        '<div class="variations-table" id="variations-' + product.id + '">' +
        '<table><thead><tr>' + thHtml + '</tr></thead><tbody>' + trHtml + '</tbody></table>' +
        moreHtml + '</div></div>';
    }

    return '<article class="soeteck-product-list-item" data-product-id="' + product.id + '">' +
      '<div class="soeteck-product-list-card">' +
        '<div class="soeteck-product-list-card__media soeteck-product-list-card__gallery" role="group" aria-label="' + product.title.replace(/"/g, '&quot;') + '">' + galleryHtml + '</div>' +
        '<div class="soeteck-product-list-card__content">' +
          '<h3 class="soeteck-card-title soeteck-product-list-card__title"><a href="' + product.path + '" target="_blank" rel="noopener noreferrer">' + product.title + '</a></h3>' +
          (product.excerpt ? '<p class="soeteck-product-list-card__excerpt">' + product.excerpt + '</p>' : '') +
        '</div>' +
        '<div class="soeteck-product-list-card__actions">' + actionsHtml + '</div>' +
      '</div>' +
      modelsHtml +
    '</article>';
  }

  function renderGrid() {
    var filtered = getFilteredProducts();
    var totalFiltered = filtered.length;
    var totalPages = Math.max(1, Math.ceil(totalFiltered / perPage));
    if (currentPage > totalPages) currentPage = totalPages;

    var start = (currentPage - 1) * perPage;
    var end = Math.min(start + perPage, totalFiltered);
    var pageProducts = filtered.slice(start, end);

    if (resultCountEl) {
      if (totalFiltered <= perPage) {
        resultCountEl.textContent = (labels.showingAll || 'Showing all {count} results').replace('{count}', totalFiltered);
      } else {
        resultCountEl.textContent = (labels.showingRange || 'Showing {start}–{end}, {total} results')
          .replace('{start}', start + 1).replace('{end}', end).replace('{total}', totalFiltered);
      }
    }

    if (gridContainer) {
      if (pageProducts.length === 0) {
        gridContainer.innerHTML = '<div class="soeteck-product-empty"><p>' + (labels.noResults || 'No products found matching your criteria.') + '</p></div>';
      } else {
        gridContainer.innerHTML = '<div class="soeteck-product-list">' +
          pageProducts.map(renderCard).join('') +
          '</div>';
        initGalleryCarousels();
        initModelsToggles();
      }
    }

    renderPagination(totalPages);
    renderActiveFilters();
    updatePendingFilters();
  }

  function renderPagination(totalPages) {
    if (!paginationEl) return;
    if (totalPages <= 1) {
      paginationEl.innerHTML = '';
      return;
    }

    var html = '<nav class="woocommerce-pagination" aria-label="Product pagination"><ul class="page-numbers">';

    if (currentPage > 1) {
      html += '<li><a class="page-numbers prev" href="#" data-page="' + (currentPage - 1) + '">&laquo;</a></li>';
    }

    for (var i = 1; i <= totalPages; i++) {
      if (i === currentPage) {
        html += '<li><span class="page-numbers current" aria-current="page">' + i + '</span></li>';
      } else if (i <= 3 || i > totalPages - 2 || Math.abs(i - currentPage) <= 1) {
        html += '<li><a class="page-numbers" href="#" data-page="' + i + '">' + i + '</a></li>';
      } else if ((i === 4 && currentPage > 5) || (i === totalPages - 2 && currentPage < totalPages - 4)) {
        html += '<li><span class="page-numbers dots">&hellip;</span></li>';
      }
    }

    if (currentPage < totalPages) {
      html += '<li><a class="page-numbers next" href="#" data-page="' + (currentPage + 1) + '">&raquo;</a></li>';
    }

    html += '</ul></nav>';
    paginationEl.innerHTML = html;

    paginationEl.querySelectorAll('[data-page]').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        currentPage = parseInt(this.getAttribute('data-page'), 10);
        renderGrid();
        var toolbar = document.querySelector('.soeteck-product-toolbar');
        if (toolbar) toolbar.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }

  function renderActiveFilters() {
    if (!activeFiltersEl) return;
    var hasAny = filterGroups.some(function(g) { return (activeFilters[g.key] || []).length > 0; });
    var form = document.getElementById('soeteck-product-filters-form');
    var clearAction = filtersContainer && filtersContainer.querySelector('.soeteck-product-filters__clear-action');
    if (clearAction) clearAction.setAttribute('data-has-active-filters', hasAny ? 'true' : 'false');
    if (!hasAny) {
      activeFiltersEl.style.display = 'none';
      if (filtersContainer) {
        filtersContainer.classList.remove('has-active-filters');
      }
      if (form) form.classList.remove('has-active-filters');
      return;
    }

    activeFiltersEl.style.display = 'flex';
    if (filtersContainer) {
      filtersContainer.classList.add('has-active-filters');
    }
    if (form) form.classList.add('has-active-filters');

    var html = '';
    filterGroups.forEach(function(group) {
      var selected = activeFilters[group.key] || [];
      selected.forEach(function(termId) {
        var term = group.terms.find(function(t) { return String(t.id) === String(termId); });
        if (term) {
          html += '<a class="soeteck-active-filter" href="#" data-group="' + group.key + '" data-term="' + termId + '">' +
            '<span>' + term.name + '</span>' +
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>' +
            '</a>';
        }
      });
    });

    html += '<a class="soeteck-active-filters__clear" href="#" id="clear-all-filters">' + (labels.clearAll || 'Clear all') + '</a>';
    activeFiltersEl.innerHTML = html;

    activeFiltersEl.querySelectorAll('.soeteck-active-filter').forEach(function(el) {
      el.addEventListener('click', function(e) {
