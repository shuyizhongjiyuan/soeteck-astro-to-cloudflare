---
interface Props {
  eyebrow: string;
  title: string;
  text?: string;
  id?: string;
}

const { eyebrow, title, text, id } = Astro.props;
---
<div class="about-section-heading">
  <p class="soeteck-eyebrow">{eyebrow}</p>
  <h2 id={id}>{title}</h2>
  {text && <p>{text}</p>}
</div>

<style>
  .about-section-heading {
    max-width: 820px;
    margin-bottom: clamp(32px, 4vw, 48px);
  }

  .about-section-heading h2 {
    margin: 0;
    color: var(--soeteck-text);
    font-size: clamp(1.85rem, 3.1vw, 3rem);
    line-height: 1.14;
  }

  .about-section-heading p:not(.soeteck-eyebrow) {
    margin: 20px 0 0;
    color: var(--soeteck-text-soft);
    font-size: var(--soeteck-text-md);
    line-height: 1.7;
  }
</style>
