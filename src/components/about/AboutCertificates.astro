---
import type { PageImage } from '@/lib/page-adapter';

interface Props {
  images: PageImage[];
  points: string[];
  eyebrow?: string;
  title?: string;
  text?: string;
}

const { images, points, eyebrow = 'Featured Certificates', title = 'Quality systems for safety, sustainability, and excellence.', text = 'We maintain rigorous quality and environmental management practices, including ISO9001, ISO14001, ISO45001, and product certifications such as CE, reinforcing our commitment to international standards.' } = Astro.props;
---
<section class="about-section certificates" aria-labelledby="about-certificates-title">
  <div class="soeteck-container">
    <div class="certificates__intro">
      <p class="soeteck-eyebrow">{eyebrow}</p>
      <h2 id="about-certificates-title">{title}</h2>
      <p>{text}</p>
      <div class="certificates__points">
        {points.map((point) => <span>{point}</span>)}
      </div>
    </div>
    <div class="certificates__grid">
      {images.map((image) => (
        <figure>
          <a class="certificates__link" href={image.path} data-soeteck-lightbox data-lightbox-src={image.path} data-lightbox-group="about-certificates" aria-label={image.alt || 'View SOETECK certificate'}>
            <img class="certificates__image" src={image.path} alt={image.alt} loading="lazy" />
          </a>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: clamp(64px, 7vw, 108px) 0;
  }

  .certificates__intro {
    max-width: 860px;
    margin-bottom: clamp(32px, 4vw, 48px);
  }

  .certificates__intro h2 {
    margin: 0;
    color: var(--soeteck-text);
    font-size: clamp(1.85rem, 3.1vw, 3rem);
    line-height: 1.14;
  }

  .certificates__intro p:not(.soeteck-eyebrow) {
    margin: 22px 0 0;
    color: var(--soeteck-text-soft);
    line-height: 1.72;
  }

  .certificates__points {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 26px;
  }

  .certificates__points span {
    display: inline-flex;
    padding: 9px 13px;
    border: 1px solid var(--soeteck-border-soft);
    border-radius: 999px;
    background: var(--soeteck-surface);
    color: var(--soeteck-text);
    font-size: var(--soeteck-text-xs);
    font-weight: var(--soeteck-weight-semibold);
  }

  .certificates__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .certificates__grid figure {
    display: grid;
    min-height: 220px;
    margin: 0;
    place-items: center;
    padding: 14px;
    border: 1px solid var(--soeteck-border-soft);
    border-radius: var(--soeteck-radius-md);
    background: #fff;
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.05);
  }

  .certificates__link {
    display: grid;
    width: 100%;
    height: 100%;
    place-items: center;
    border-radius: calc(var(--soeteck-radius-md) - 4px);
  }

  .certificates__image {
    width: 100%;
    height: auto;
    max-height: 260px;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .about-section {
      padding-block: 56px;
    }

    .certificates__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .certificates__grid {
      gap: 10px;
    }

    .certificates__grid figure {
      min-height: 164px;
      padding: 10px;
    }
  }
</style>
