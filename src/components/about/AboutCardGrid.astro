---
interface Card {
  eyebrow?: string;
  title: string;
  text: string;
  value?: string;
  label?: string;
}

interface Props {
  cards: Card[];
  variant: 'deliver' | 'proof' | 'service' | 'process' | 'network';
}

const { cards, variant } = Astro.props;
---
<div class:list={['about-card-grid', `about-card-grid--${variant}`]}>
  {cards.map((card) => (
    <article class:list={['about-card', `about-card--${variant}`]}>
      {card.value && <strong>{card.value}</strong>}
      {card.eyebrow && <span>{card.eyebrow}</span>}
      {card.label && <span>{card.label}</span>}
      <h3>{card.title}</h3>
      <p>{card.text}</p>
    </article>
  ))}
</div>

<style>
  .about-card-grid {
    display: grid;
    gap: 18px;
  }

  .about-card-grid--deliver,
  .about-card-grid--process {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .about-card-grid--proof,
  .about-card-grid--service {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .about-card-grid--network {
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
    margin-top: clamp(28px, 4vw, 46px);
  }

  .about-card {
    position: relative;
    overflow: hidden;
  }

  .about-card--deliver {
    min-height: 230px;
    padding: 28px 24px;
    border: 1px solid rgba(226, 232, 240, 0.95);
    border-radius: var(--soeteck-radius-lg);
    background: linear-gradient(135deg, rgba(0, 102, 204, 0.06), transparent 42%), #fff;
    box-shadow: 0 16px 42px rgba(15, 23, 42, 0.055);
  }

  .about-card--proof {
    min-height: 230px;
    padding: 26px 22px;
    border: 1px solid rgba(196, 211, 226, 0.75);
    border-radius: var(--soeteck-radius-lg);
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 18px 48px rgba(15, 23, 42, 0.06);
    backdrop-filter: blur(10px);
  }

  .about-card--service {
    min-height: 280px;
    padding: 30px 24px;
    border: 1px solid rgba(226, 232, 240, 0.92);
    border-radius: var(--soeteck-radius-lg);
    background: #fff;
    box-shadow: 0 16px 42px rgba(15, 23, 42, 0.06);
  }

  .about-card--process {
    min-height: 230px;
    padding: 28px 24px 26px;
    border: 1px solid rgba(196, 211, 226, 0.72);
    border-radius: var(--soeteck-radius-lg);
    background: linear-gradient(180deg, #ffffff, #f8fbff);
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.05);
  }

  .about-card--network {
    min-height: 190px;
    padding: 22px 18px;
    border: 1px solid rgba(196, 211, 226, 0.72);
    border-radius: var(--soeteck-radius-md);
    background: linear-gradient(180deg, #ffffff, #f8fbff);
    box-shadow: 0 14px 36px rgba(15, 23, 42, 0.05);
  }

  .about-card--deliver::before {
    content: '';
    display: block;
    width: 44px;
    height: 4px;
    margin-bottom: 28px;
    border-radius: 999px;
    background: var(--soeteck-primary);
  }

  .about-card--service::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: linear-gradient(180deg, var(--soeteck-primary), rgba(0, 102, 204, 0.08));
  }

  .about-card--network::after {
    content: '';
    position: absolute;
    right: -22px;
    bottom: -22px;
    width: 72px;
    height: 72px;
    border: 1px solid rgba(0, 102, 204, 0.18);
    border-radius: 50%;
  }

  .about-card strong {
    display: block;
    color: var(--soeteck-primary);
    font-family: var(--soeteck-font-heading);
    font-size: clamp(1.9rem, 2.8vw, 3.1rem);
    line-height: 1;
  }

  .about-card span {
    display: inline-flex;
    color: var(--soeteck-primary);
    font-weight: var(--soeteck-weight-bold);
    text-transform: uppercase;
  }

  .about-card--service > span,
  .about-card--network > span {
    font-size: var(--soeteck-text-xs);
  }

  .about-card--service > span {
    margin-bottom: 22px;
    letter-spacing: 0.12em;
  }

  .about-card--network > span {
    letter-spacing: 0.12em;
  }

  .about-card--process > span {
    display: inline-grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border-radius: 50%;
    background: rgba(0, 102, 204, 0.1);
    font-family: var(--soeteck-font-heading);
    font-size: var(--soeteck-text-sm);
  }

  .about-card strong + span {
    display: block;
    margin-top: 14px;
    color: var(--soeteck-text);
    font-size: var(--soeteck-text-sm);
    letter-spacing: 0.08em;
  }

  .about-card h3 {
    color: var(--soeteck-text);
    line-height: 1.28;
  }

  .about-card--deliver h3 {
    margin: 0;
    font-size: clamp(1.12rem, 1.35vw, 1.36rem);
    line-height: 1.25;
  }

  .about-card--service h3 {
    margin: 0;
    font-size: clamp(1.15rem, 1.45vw, 1.4rem);
  }

  .about-card--process h3 {
    margin: 22px 0 0;
    font-size: clamp(1.12rem, 1.35vw, 1.32rem);
  }

  .about-card--network h3 {
    position: relative;
    z-index: 1;
    margin: 18px 0 0;
    font-size: 1.08rem;
  }

  .about-card--proof h3 {
    display: none;
  }

  .about-card p {
    color: var(--soeteck-text-soft);
    font-size: var(--soeteck-text-sm);
  }

  .about-card--deliver p,
  .about-card--service p {
    margin: 16px 0 0;
  }

  .about-card--deliver p {
    line-height: 1.68;
  }

  .about-card--proof p,
  .about-card--process p {
    margin: 14px 0 0;
    line-height: 1.66;
  }

  .about-card--service p {
    line-height: 1.7;
  }

  .about-card--network p {
    position: relative;
    z-index: 1;
    margin: 12px 0 0;
    line-height: 1.62;
  }

  @media (max-width: 1200px) {
    .about-card-grid--proof,
    .about-card-grid--service,
    .about-card-grid--network {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 991px) {
    .about-card-grid--deliver,
    .about-card-grid--proof,
    .about-card-grid--service,
    .about-card-grid--process,
    .about-card-grid--network {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .about-card-grid--deliver,
    .about-card-grid--proof,
    .about-card-grid--service,
    .about-card-grid--process,
    .about-card-grid--network {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .about-card {
      padding: 24px 20px;
    }
  }
</style>
