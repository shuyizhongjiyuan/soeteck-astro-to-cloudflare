---
interface Props {
  href: string;
  eyebrow?: string;
  title?: string;
  text?: string;
  checks?: string[];
  button?: string;
}

const { href, eyebrow = 'Talk to an Engineer', title = 'Share your facility requirements and get a practical solution path.', text = 'Tell us your facility type, load, cooling requirement, project timeline, and target region. Our team will help identify the right power, cooling, or modular data center configuration.', checks = ['Project consultation', 'Technical configuration support', 'Regional communication follow-up'], button = 'Request Project Consultation' } = Astro.props;
---
<section class="about-cta" aria-labelledby="about-cta-title">
  <div class="soeteck-container about-cta__inner">
    <div>
      <p class="soeteck-eyebrow">{eyebrow}</p>
      <h2 id="about-cta-title">{title}</h2>
      <p>{text}</p>
      <ul class="about-cta__checks">
        {checks.map((check: string) => <li>{check}</li>)}
      </ul>
    </div>
    <a class="about-cta__button" href={href}>{button}</a>
  </div>
</section>

<style>
  .about-cta {
    position: relative;
    overflow: hidden;
    padding: clamp(64px, 7vw, 108px) 0;
    background: radial-gradient(circle at 78% 18%, rgba(0, 102, 204, 0.28), transparent 34%), linear-gradient(135deg, #061529 0%, #0a2749 56%, #061529 100%);
    color: #fff;
  }

  .about-cta::before {
    content: '';
    position: absolute;
    inset: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    pointer-events: none;
  }

  .about-cta__inner {
    position: relative;
    display: flex;
    gap: 32px;
    align-items: center;
    justify-content: space-between;
  }

  .about-cta h2 {
    margin: 0;
    color: #fff;
    font-size: clamp(1.85rem, 3.1vw, 3rem);
    line-height: 1.14;
  }

  .about-cta p:not(.soeteck-eyebrow) {
    max-width: 820px;
    margin: 22px 0 0;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.72;
  }

  .about-cta__checks {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 26px 0 0;
    padding: 0;
    list-style: none;
  }

  .about-cta__checks li {
    padding: 8px 12px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.86);
    font-size: var(--soeteck-text-sm);
    font-weight: var(--soeteck-weight-semibold);
  }

  .about-cta__button {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 999px;
    background: var(--soeteck-primary);
    color: #fff;
    font-weight: 700;
    box-shadow: 0 16px 36px rgba(0, 102, 204, 0.28);
  }

  .about-cta__button:hover {
    color: #fff;
    background: var(--soeteck-primary-dark);
  }

  @media (max-width: 991px) {
    .about-cta__inner {
      display: grid;
      justify-items: start;
    }
  }

  @media (max-width: 768px) {
    .about-cta {
      padding-block: 56px;
    }
  }

  @media (max-width: 480px) {
    .about-cta__button {
      width: 100%;
      justify-content: center;
    }
  }
</style>
