  var groupsContainer = document.querySelector('.soeteck-product-filters__groups');
  if (groupsContainer) {
    var openedGroups = Array.from(groupsContainer.querySelectorAll('.soeteck-filter-group.is-open'));

    groupsContainer.querySelectorAll('.soeteck-filter-group__toggle').forEach(function(button) {
      button.addEventListener('click', function() {
        var group = button.closest('.soeteck-filter-group');
        if (!group) return;
