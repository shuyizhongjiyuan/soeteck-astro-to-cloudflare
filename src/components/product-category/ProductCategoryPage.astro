  /* === Gallery Carousel (main.js lines 352-473) === */
  function initGalleryCarousels() {
    document.querySelectorAll('.soeteck-product-list-card__gallery').forEach(function(gallery) {
      var track = gallery.querySelector('.soeteck-product-list-card__gallery-track');
      var slides = Array.from(gallery.querySelectorAll('[data-gallery-slide]'));
      var dots = Array.from(gallery.querySelectorAll('[data-gallery-dot]'));
      var activeIndex = 0;
      var startX = 0;
      var dragging = false;
      var dragOffset = 0;
      var dragged = false;

      if (slides.length <= 1) return;

      function updateActiveState() {
        slides.forEach(function(slide, i) {
          slide.classList.toggle('is-active', i === activeIndex);
        });
        dots.forEach(function(dot, i) {
          var active = i === activeIndex;
          dot.classList.toggle('is-active', active);
          if (active) dot.setAttribute('aria-current', 'true');
          else dot.removeAttribute('aria-current');
        });
      }

      function setActive(index) {
        var nextIndex = (index + slides.length) % slides.length;
        var isLastToFirst = activeIndex === slides.length - 1 && nextIndex === 0;
        activeIndex = nextIndex;
        dragOffset = 0;
        if (track) {
          gallery.classList.toggle('is-looping-forward', isLastToFirst);
          track.style.setProperty('--gallery-index', activeIndex);
          track.style.setProperty('--gallery-drag-offset', '0px');
          if (isLastToFirst) {
            setTimeout(function() { gallery.classList.remove('is-looping-forward'); }, 300);
          }
        }
        updateActiveState();
      }

      dots.forEach(function(dot, i) {
        dot.addEventListener('click', function(event) {
          event.preventDefault();
          event.stopPropagation();
          setActive(i);
        });
      });

      gallery.addEventListener('pointerdown', function(event) {
        if ((event.pointerType === 'mouse' && event.button !== 0) || event.target.closest('[data-gallery-dot]')) return;
        event.preventDefault();
        dragging = true;
        dragOffset = 0;
        startX = event.clientX;
        if (track) track.style.setProperty('--gallery-drag-offset', '0px');
        gallery.classList.add('is-dragging');
        gallery.setPointerCapture(event.pointerId);
      });

      gallery.addEventListener('pointermove', function(event) {
        if (!dragging) return;
        dragOffset = event.clientX - startX;
        if (Math.abs(dragOffset) > 8) dragged = true;
        if (track) track.style.setProperty('--gallery-drag-offset', dragOffset + 'px');
      });

      gallery.addEventListener('pointerup', function(event) {
        if (!dragging) return;
        var deltaX = event.clientX - startX;
        dragging = false;
        gallery.classList.remove('is-dragging');
        if (gallery.hasPointerCapture(event.pointerId)) gallery.releasePointerCapture(event.pointerId);
        if (Math.abs(deltaX) > 35) {
          event.preventDefault();
          setActive(activeIndex + (deltaX < 0 ? 1 : -1));
        } else if (track) {
          dragOffset = 0;
          track.style.setProperty('--gallery-drag-offset', '0px');
        }
        setTimeout(function() { dragged = false; }, 0);
      });

      gallery.addEventListener('pointercancel', function(event) {
        dragging = false;
        dragOffset = 0;
        gallery.classList.remove('is-dragging');
        if (track) track.style.setProperty('--gallery-drag-offset', '0px');
        if (gallery.hasPointerCapture(event.pointerId)) gallery.releasePointerCapture(event.pointerId);
      });

      gallery.addEventListener('click', function(event) {
        if (dragged) { event.preventDefault(); return; }
        if (!event.target.closest('[data-gallery-dot]')) event.preventDefault();
      });
    });
