---
import AboutCardGrid from './AboutCardGrid.astro';
import type { PageImage } from '@/lib/page-adapter';

interface NetworkNode {
  eyebrow: string;
  title: string;
  text: string;
}

interface Props {
  image: PageImage;
  nodes: NetworkNode[];
  eyebrow?: string;
  title?: string;
  text?: string;
}

const { image, nodes, eyebrow = 'Global Network & Industrial Partners', title = 'Regional presence and partner coverage for international infrastructure projects.', text = 'With branches and offices in over 50 countries and a presence in 86 markets, SOETECK combines manufacturing capability with regional communication channels and partner relationships.' } = Astro.props;
---
<section class="about-section global" aria-labelledby="about-global-title">
  <div class="soeteck-container">
    <div class="global__grid">
      <div>
        <p class="soeteck-eyebrow">{eyebrow}</p>
        <h2 id="about-global-title">{title}</h2>
        <p>{text}</p>
      </div>
      <div class="global__map">
        <img class="global__image" src={image.path} alt={image.alt} loading="lazy" />
        <span class="hotspot hotspot--china" aria-label="China network presence"></span>
        <span class="hotspot hotspot--uae" aria-label="UAE partner presence"></span>
        <span class="hotspot hotspot--malaysia" aria-label="Malaysia network presence"></span>
        <span class="hotspot hotspot--europe" aria-label="Europe market coverage"></span>
        <span class="hotspot hotspot--americas" aria-label="Americas market coverage"></span>
      </div>
    </div>
    <AboutCardGrid cards={nodes} variant="network" />
  </div>
</section>

<style>
  .about-section {
    padding: clamp(64px, 7vw, 108px) 0;
  }

  .global {
    background: var(--soeteck-surface);
  }

  .global__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.75fr) minmax(0, 1fr);
    gap: clamp(44px, 7vw, 96px);
    align-items: center;
  }

  .global h2 {
    margin: 0;
    color: var(--soeteck-text);
    font-size: clamp(1.85rem, 3.1vw, 3rem);
    line-height: 1.14;
  }

  .global p:not(.soeteck-eyebrow) {
    margin: 22px 0 0;
    color: var(--soeteck-text-soft);
    line-height: 1.72;
  }

  .global__map {
    position: relative;
    overflow: hidden;
    border-radius: var(--soeteck-radius-lg);
    background: #fff;
    box-shadow: 0 22px 58px rgba(15, 23, 42, 0.08);
    padding: clamp(22px, 4vw, 42px);
  }

  .global__image {
    width: 100%;
    height: auto;
  }

  .hotspot {
    position: absolute;
    z-index: 2;
    width: 10px;
    height: 10px;
    border: 2px solid #fff;
    border-radius: 50%;
    background: var(--soeteck-primary);
    box-shadow: 0 0 0 6px rgba(0, 102, 204, 0.14), 0 10px 22px rgba(15, 23, 42, 0.18);
  }

  .hotspot::after {
    content: '';
    position: absolute;
    inset: -10px;
    border: 1px solid rgba(0, 102, 204, 0.32);
    border-radius: 50%;
    animation: hotspot-pulse 1800ms ease-out infinite;
  }

  .hotspot--china { top: 45%; left: 72%; }
  .hotspot--uae { top: 50%; left: 59%; }
  .hotspot--malaysia { top: 62%; left: 70%; }
  .hotspot--europe { top: 36%; left: 49%; }
  .hotspot--americas { top: 48%; left: 25%; }

  @keyframes hotspot-pulse {
    0% { opacity: 0.85; transform: scale(0.7); }
    100% { opacity: 0; transform: scale(1.9); }
  }

  @media (max-width: 991px) {
    .global__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .about-section {
      padding-block: 56px;
    }
  }
</style>
