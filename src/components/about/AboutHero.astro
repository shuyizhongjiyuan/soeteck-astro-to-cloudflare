---
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import type { PageBreadcrumb, PageImage } from '@/lib/page-adapter';

interface Props {
  title: string;
  lead: string;
  image: PageImage;
  breadcrumbs: PageBreadcrumb[];
  eyebrow?: string;
  lang?: string;
}

const { title, lead, image, breadcrumbs, eyebrow = 'Critical Infrastructure Manufacturer', lang = 'en' } = Astro.props;
---
<section class="about-hero" aria-labelledby="about-title">
  <img class="about-hero__image" src={image.path} alt={image.alt} loading="eager" />
  <div class="about-hero__overlay" aria-hidden="true"></div>
  <div class="soeteck-container about-hero__breadcrumbs">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>
  <div class="soeteck-container about-hero__content">
    <p class="about-hero__eyebrow">{eyebrow}</p>
    <h1 id="about-title">{title}</h1>
    <p>{lead}</p>
  </div>
</section>

<style>
  .about-hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 480px;
    overflow: hidden;
    background: var(--soeteck-dark);
    color: #fff;
  }

  .about-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center center;
  }

  .about-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(6, 21, 41, 0.88), rgba(10, 39, 73, 0.58), rgba(10, 39, 73, 0.16)), linear-gradient(180deg, rgba(6, 21, 41, 0.08), rgba(6, 21, 41, 0.42));
  }

  .about-hero__breadcrumbs {
    position: absolute;
    top: 15px;
    left: 50%;
    z-index: 2;
    transform: translateX(-50%);
  }

  .about-hero__breadcrumbs :global(.breadcrumbs) {
    margin: 0;
    color: rgba(255, 255, 255, 0.78);
  }

  .about-hero__breadcrumbs :global(a) {
    color: rgba(255, 255, 255, 0.86);
  }

  .about-hero__content {
    position: relative;
    z-index: 1;
    padding-block: 72px;
  }

  .about-hero__eyebrow {
    margin: 0 0 18px;
    color: rgba(255, 255, 255, 0.72);
    font-size: var(--soeteck-text-sm);
    font-weight: var(--soeteck-weight-bold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .about-hero h1 {
    max-width: 780px;
    margin: 0;
    color: #fff;
    font-size: var(--soeteck-heading-lg);
    line-height: 1.08;
  }

  .about-hero p:not(.about-hero__eyebrow) {
    max-width: 760px;
    margin: 22px 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: clamp(1.05rem, 1.4vw, 1.35rem);
    line-height: 1.6;
  }

  @media (min-width: 481px) {
    .about-hero__breadcrumbs {
      top: 20px;
    }
  }

  @media (max-width: 991px) {
    .about-hero {
      min-height: 420px;
    }
  }

  @media (max-width: 640px) {
    .about-hero {
      min-height: 360px;
    }

    .about-hero__content {
      padding-block: 56px;
    }
  }
</style>
